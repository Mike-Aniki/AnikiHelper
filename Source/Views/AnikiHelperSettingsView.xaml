                                   Margin="0,2,0,2"
                                   TextWrapping="Wrap"/>

                                <TextBlock Text="{DynamicResource NewsScan_Enable_Help2_Line2}"
                                   Style="{StaticResource SmallNoteText}"
                                   Margin="0,2,0,2"
                                   TextWrapping="Wrap"/>

                                <TextBlock Text="{DynamicResource NewsScan_Enable_Help2_Line3}"
                                   Style="{StaticResource SmallNoteText}"
                                   Margin="0,2,0,2"
                                   TextWrapping="Wrap"/>


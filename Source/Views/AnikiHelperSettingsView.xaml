                                    <TextBlock Text="{DynamicResource SteamStore_Enable_Help}"
                                   Style="{StaticResource SmallNoteText}"
                                   Margin="0,0,0,0"
                                   TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>




            <!-- ========= ANIKI NEWS FEATURES ========= -->
            <TabItem Header="{DynamicResource GroupAnikiFeatures}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->

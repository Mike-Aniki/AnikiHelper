                                <TextBlock Text="{DynamicResource NewsScan_Enable_Help}"
                                   Style="{StaticResource SmallNoteText}"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"/>

                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">

                            <StackPanel Margin="12,10,12,12">

                                <TextBlock Text="{DynamicResource AnikiNews_Title1}"
    FontWeight="SemiBold"
    Foreground="White"
    TextWrapping="Wrap"/>

                                <TextBlock Text="{DynamicResource AnikiNews_CustomFeed_Desc2}"
                                   Style="{StaticResource SmallNoteText}"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"/>

                                <!-- SOURCE A -->
                                <TextBlock Text="{DynamicResource AnikiNews_SourceA_Title}"

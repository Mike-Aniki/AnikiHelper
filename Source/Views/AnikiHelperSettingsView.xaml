<UserControl x:Class="AnikiHelper.AnikiHelperSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="639"
             d:DesignHeight="399">

    <UserControl.Resources>

        <SolidColorBrush x:Key="Surface1Brush" Color="#15FFFFFF"/>

        <!-- Borders / separators -->
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushHover" Color="#3DFFFFFF"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#1FFFFFFF"/>

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8A8A8A"/>

        <!-- Single accent (keep your identity here) -->
        <SolidColorBrush x:Key="AccentBrush" Color="#FFB37AFF"/>

        <!-- Cards -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="Padding" Value="12"/>
            <!-- Shadow: très soft -->
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.18"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header inside card -->
        <Style x:Key="SectionHeaderBar" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SectionHeaderTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionSeparator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SeparatorBrush}"/>
            <Setter Property="Margin" Value="0,12,0,12"/>
        </Style>

        <Style x:Key="SmallNoteText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Buttons: flat clean -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1FFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,2"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2AFFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>




    <Grid Margin="16,12,16,16">
        <TabControl>

            <!-- ========== GENERAL ========== -->
            <TabItem Header="General" ToolTip="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->
                        <Border CornerRadius="14"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Background="Transparent"
                                Padding="14"
                                Margin="0,0,0,5">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource AppTitle}"
                                           FontWeight="Bold"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <Border Background="#2200AEEF"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,6,0,10"
                                        MaxWidth="650"
                                        HorizontalAlignment="Center">

                                    <TextBlock Text="{DynamicResource AppInfo}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                </Border>



                            </StackPanel>
                        </Border>

                        <Border Height="1"
                                Background="{StaticResource SeparatorBrush}"
                                Margin="0,6,0,10"/>

                        <!-- ========= HUB ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource WelcomeHubStartup_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource WelcomeHubStartup_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource WelcomeHubStartup_Enable}"
                                              IsChecked="{Binding Settings.OpenWelcomeHubOnStartup, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource WelcomeHubStartup_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"/>

                                    <Border Height="1"
                                            Background="{StaticResource SeparatorBrush}"
                                            Margin="0,10,0,12"/>

                                    <TextBlock Text="{DynamicResource HubApps_Title}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Text="{DynamicResource HubApps_Desc}"
                                               Style="{StaticResource SmallNoteText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>

                                    <CheckBox Content="{DynamicResource HubApps_Enable}"
                                              IsChecked="{Binding Settings.HubAppsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,10"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource HubApps_Slot1}" Style="{StaticResource SmallNoteText}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Settings.SoftwareToolNamesForSelection}" SelectedItem="{Binding Settings.HubAppSlot1ToolName, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding Settings.HubAppSlot1BackgroundPath, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <Button Grid.Row="0" Grid.Column="3" Content="{DynamicResource BrowseImage}" Click="BrowseHubAppSlot1Background_Click" MinHeight="28" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource HubApps_Slot2}" Style="{StaticResource SmallNoteText}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Settings.SoftwareToolNamesForSelection}" SelectedItem="{Binding Settings.HubAppSlot2ToolName, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Settings.HubAppSlot2BackgroundPath, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <Button Grid.Row="1" Grid.Column="3" Content="{DynamicResource BrowseImage}" Click="BrowseHubAppSlot2Background_Click" MinHeight="28" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource HubApps_Slot3}" Style="{StaticResource SmallNoteText}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Settings.SoftwareToolNamesForSelection}" SelectedItem="{Binding Settings.HubAppSlot3ToolName, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding Settings.HubAppSlot3BackgroundPath, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,8"/>
                                        <Button Grid.Row="2" Grid.Column="3" Content="{DynamicResource BrowseImage}" Click="BrowseHubAppSlot3Background_Click" MinHeight="28" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource HubApps_Slot4}" Style="{StaticResource SmallNoteText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Settings.SoftwareToolNamesForSelection}" SelectedItem="{Binding Settings.HubAppSlot4ToolName, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Settings.HubAppSlot4BackgroundPath, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" Margin="0,0,8,0"/>
                                        <Button Grid.Row="3" Grid.Column="3" Content="{DynamicResource BrowseImage}" Click="BrowseHubAppSlot4Background_Click" MinHeight="28"/>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource HubApps_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= SOUNDS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource EventSounds_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">


                                    <TextBlock Text="{DynamicResource EventSounds_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource EventSounds_Enable}"
                                              IsChecked="{Binding Settings.EventSoundsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource EventSounds_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= VIDEO ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource Video}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">


                                    <!-- ========= Video ========= -->
                                    <TextBlock Text="{DynamicResource StartupIntro_Title}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource StartupIntro_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource StartupIntro_Enable}"
                                              IsChecked="{Binding Settings.StartupIntroVideoEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource IntroVideo_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource ShutdownVideo_Title}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource ShutdownVideo_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource ShutdownVideo_Enable}"
                                              IsChecked="{Binding Settings.ShutdownVideoEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource ShutdownVideo_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>





                        <!-- ========= CUSTOM ICONS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource CustomIcons_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource CustomIcons_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource CustomIcons_FilterFolder}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,12,0,4"/>

                                    <DockPanel LastChildFill="True"
                                               Margin="0,4,0,8">

                                        <Button Content="{DynamicResource BrowseFolder}"
                                                Width="100"
                                                Margin="8,0,0,0"
                                                DockPanel.Dock="Right"
                                                Click="BrowseFilterIconsFolder_Click"/>

                                        <TextBox Text="{Binding Settings.CustomFilterIconsFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="28"/>
                                    </DockPanel>

                                    <TextBlock Text="{DynamicResource CustomIcons_SourceFolder}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,12,0,4"/>

                                    <DockPanel LastChildFill="True"
                                               Margin="0,4,0,8">

                                        <Button Content="{DynamicResource BrowseFolder}"
                                                Width="100"
                                                Margin="8,0,0,0"
                                                DockPanel.Dock="Right"
                                                Click="BrowseSourceIconsFolder_Click"/>

                                        <TextBox Text="{Binding Settings.CustomSourceIconsFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="28"/>
                                    </DockPanel>

                                    <TextBlock Text="{DynamicResource CustomIcons_BannerAboveCoverFolder}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,12,0,4"/>

                                    <DockPanel LastChildFill="True"
                                               Margin="0,4,0,8">

                                        <Button Content="{DynamicResource BrowseFolder}"
                                                Width="100"
                                                Margin="8,0,0,0"
                                                DockPanel.Dock="Right"
                                                Click="BrowseBannerAboveCoverFolder_Click"/>

                                        <TextBox Text="{Binding Settings.CustomBannerAboveCoverFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="28"/>
                                    </DockPanel>

                                    <TextBlock Text="{DynamicResource CustomIcons_BannerOnCoverFolder}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,12,0,4"/>

                                    <DockPanel LastChildFill="True"
                                               Margin="0,4,0,8">

                                        <Button Content="{DynamicResource BrowseFolder}"
                                                Width="100"
                                                Margin="8,0,0,0"
                                                DockPanel.Dock="Right"
                                                Click="BrowseBannerOnCoverFolder_Click"/>

                                        <TextBox Text="{Binding Settings.CustomBannerOnCoverFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="28"/>
                                    </DockPanel>

                                    <TextBlock Text="{DynamicResource CustomIcons_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= MEDIA GALLERY ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource MediaGallery_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource MediaGallery_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource MediaGallery_GenerateThumbnails}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource MediaGallery_GenerateThumbnails_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,8"/>

                                    <Button Content="{DynamicResource MediaGallery_GenerateThumbnails_Button}"
                                            Command="{Binding Settings.GenerateMediaThumbnailsCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Width="260"
                                            Margin="0,4,0,8"/>

                                    <TextBlock Text="{Binding Settings.MediaThumbnailPrecacheStatus}"
                                           Style="{StaticResource SmallNoteText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= ACHIEVEMENTS CACHE ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource AchievementCache_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource AchievementCache_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource AchievementCache_Rebuild}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource AchievementCache_Rebuild_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap"/>

                                    <Button Content="{Binding Settings.AchievementMemoriesRefreshButtonText}"
                                            Command="{Binding Settings.RefreshAchievementMemoriesCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Width="260"
                                            Margin="0,4,0,8"/>

                                    <TextBlock Text="{Binding Settings.AchievementMemoriesRefreshStatus}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= LIBRARY STATS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource GroupLibraryStats}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource StatsHelp}"
                                               Foreground="White"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource IncludeHidden}"
                                              IsChecked="{Binding Settings.IncludeHidden, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,0,0,6"/>

                                    <TextBlock Text="{DynamicResource AutoUpdate}"
                                               Style="{StaticResource SmallNoteText}"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <WrapPanel>
                                        <TextBlock Text="{DynamicResource PreviewTotal}"/>
                                        <TextBlock Text="{Binding Settings.TotalCount}"
                                                   FontWeight="Bold"
                                                   Margin="6,0,0,0"/>

                                        <TextBlock Margin="16,0,0,0"
                                                   Text="{DynamicResource Installed}"/>
                                        <TextBlock Text="{Binding Settings.InstalledCount}"
                                                   FontWeight="Bold"
                                                   Margin="6,0,0,0"/>

                                        <TextBlock Margin="16,0,0,0"
                                                   Text="{DynamicResource NotInstalled}"/>
                                        <TextBlock Text="{Binding Settings.NotInstalledCount}"
                                                   FontWeight="Bold"
                                                   Margin="6,0,0,0"/>
                                    </WrapPanel>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= MONTHLY TRACKING ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource GroupMonthly}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <!-- ===== GLOBAL EXPLANATION ===== -->
                                    <TextBlock Text="{DynamicResource MonthlyHelp}"
                                               Style="{StaticResource SmallNoteText}"
                                               Foreground="White"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <Border Height="1"
                                            Background="{StaticResource SeparatorBrush}"
                                            Margin="0,4,0,10"/>


                                    <!-- ===================================== -->
                                    <!-- RESET SECTION -->
                                    <!-- ===================================== -->

                                    <TextBlock Text="{DynamicResource ResetSectionTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Margin="0,4,0,6"/>

                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ResetWarningText}"
                                                   Foreground="OrangeRed"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>

                                        <Button Content="{DynamicResource ResetBtn}"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="ResetSnapshot_Click"
                                                ToolTip="{DynamicResource ResetBtnTooltip}"
                                                Width="220"
                                                Margin="0,0,0,6"/>

                                    </StackPanel>

                                    <TextBlock Text="{DynamicResource ResetBtntip}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,16"
                                               TextWrapping="Wrap"/>

                                    <Border Height="1"
                                            Background="{StaticResource SeparatorBrush}"
                                            Margin="0,6,0,10"/>


                                    <!-- ===================================== -->
                                    <!-- BACKUP SECTION -->
                                    <!-- ===================================== -->

                                    <TextBlock Text="{DynamicResource BackupSectionTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Margin="0,0,0,6"/>

                                    <TextBlock Text="{DynamicResource MonthlyBackupHelp}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,8"

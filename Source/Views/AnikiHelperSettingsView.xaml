                                           TextWrapping="Wrap"/>

                                <Border Style="{StaticResource SectionSeparator}"/>

                                <TextBlock Text="{DynamicResource GameLaunchSplash_VideoEndBehavior_Title}"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="{DynamicResource GameLaunchSplash_VideoEndBehavior_Help}"
                                           Style="{StaticResource SectionDescription}"
                                           Margin="0,4,0,6"
                                           TextWrapping="Wrap"/>

                                <ComboBox SelectedValue="{Binding Settings.GameLaunchSplashVideoEndBehavior}"
                                          SelectedValuePath="Tag"
                                          Width="320"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_VideoEndBehavior_ShowGameBackground}" Tag="ShowGameBackground"/>
                                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_VideoEndBehavior_KeepLastFrame}" Tag="KeepLastFrame"/>
                                </ComboBox>

                                <Border Style="{StaticResource SectionSeparator}"/>

                                <TextBlock Text="{DynamicResource GameLaunchSplash_SoundTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>

                                <CheckBox Content="{DynamicResource GameLaunchSplash_PauseUniPlaySong_Enable}"
                                          IsChecked="{Binding Settings.GameLaunchSplashPauseUniPlaySong, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,12,0,8"/>

                                <TextBlock Text="{DynamicResource GameLaunchSplash_PauseUniPlaySong_Help}"
                                           Style="{StaticResource SmallNoteText}"
                                           Margin="0,0,0,6"
                                           TextWrapping="Wrap"/>

                                <CheckBox Content="{DynamicResource GameLaunchSplash_VideoSound_Enable}"
                                          IsChecked="{Binding Settings.GameLaunchSplashVideoSoundEnabled, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,8,0,12"/>



                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Slider Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Width="260"
                                            Value="{Binding Settings.GameLaunchSplashVideoVolume}"/>

                                    <TextBlock Text="{Binding Settings.GameLaunchSplashVideoVolume, StringFormat={}{0:P0}}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                </StackPanel>

                                <TextBlock Text="{DynamicResource GameLaunchSplash_VideoSound_Help}"
                                           Style="{StaticResource SmallNoteText}"
                                           Margin="0,4,0,6"
                                           TextWrapping="Wrap"/>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========== IN-GAME OVERLAY ========== -->
            <TabItem Header="{DynamicResource InGameOverlay_Tab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->
                        <Border CornerRadius="14"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Background="Transparent"
                                Padding="14"
                                Margin="0,0,0,5">
                            <StackPanel HorizontalAlignment="Center">

                                <TextBlock Text="{DynamicResource AppTitle}"
                                           FontWeight="Bold"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>

                                <Border Background="#2200AEEF"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,6,0,10"
                                        MaxWidth="650"
                                        HorizontalAlignment="Center">

                                    <TextBlock Text="{DynamicResource AppInfo}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                </Border>

                            </StackPanel>
                        </Border>

                        <Border Height="1"
                                Background="{StaticResource SeparatorBrush}"
                                Margin="0,6,0,10"/>

                        <!-- ========= OVERLAY SETTINGS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource InGameOverlay_Settings_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource InGameOverlay_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource InGameOverlay_Enable}"
                                              IsChecked="{Binding Settings.InGameOverlayEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource InGameOverlay_Enable_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,12"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <!-- Keyboard shortcut -->
                                    <TextBlock Text="{DynamicResource InGameOverlay_Hotkey_Title}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,10,0,2"/>

                                    <ComboBox SelectedValue="{Binding Settings.InGameOverlayHotkey, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag"
                                              Width="320"
                                              HorizontalAlignment="Left"
                                              Margin="0,4,0,8">
                                        <ComboBoxItem Content="Ctrl + Shift + F12"
                                                      Tag="CtrlShiftF12"/>
                                        <ComboBoxItem Content="Ctrl + Alt + F12"
                                                      Tag="CtrlAltF12"/>
                                        <ComboBoxItem Content="Ctrl + F12"
                                                      Tag="CtrlF12"/>
                                        <ComboBoxItem Content="Alt + F12"
                                                      Tag="AltF12"/>
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource InGameOverlay_Hotkey_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,12"
                                               TextWrapping="Wrap"/>

                                    <!-- Controller shortcut -->
                                    <TextBlock Text="{DynamicResource InGameOverlay_ControllerShortcut_Title}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,10,0,2"/>

                                    <ComboBox SelectedValue="{Binding Settings.InGameOverlayControllerShortcut, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag"
                                              Width="320"
                                              HorizontalAlignment="Left"
                                              Margin="0,4,0,8">
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_ControllerShortcut_StartBack}"
                                                      Tag="StartBack"/>
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_ControllerShortcut_BackY}"
                                                      Tag="BackY"/>
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_ControllerShortcut_Guide}"
                                                      Tag="Guide"/>
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_ControllerShortcut_Disabled}"
                                                      Tag="Disabled"/>
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource InGameOverlay_ControllerShortcut_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <!-- Game process behavior -->
                                    <TextBlock Text="{DynamicResource InGameOverlay_GameBehavior_Title}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,10,0,2"/>

                                    <ComboBox SelectedValue="{Binding Settings.InGameOverlayGameBehavior, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag"
                                              Width="360"
                                              HorizontalAlignment="Left"
                                              Margin="0,4,0,8">
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_GameBehavior_DoNothing}"
                                                      Tag="DoNothing"/>
                                        <ComboBoxItem Content="{DynamicResource InGameOverlay_GameBehavior_SuspendGame}"
                                                      Tag="SuspendGame"/>
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource InGameOverlay_GameBehavior_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,6"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource InGameOverlay_GameBehavior_Warning}"
                                               Foreground="DarkOrange"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="0,2,0,12"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource InGameOverlay_NeverSuspendList_Title}"
                                               Style="{StaticResource SectionTitle}"
                                               Margin="0,10,0,2"/>

                                    <TextBlock Text="{DynamicResource InGameOverlay_NeverSuspendList_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,2,0,8"
                                               TextWrapping="Wrap"/>

                                    <Border Background="#10FFFFFF"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,4,0,8">
                                        <ScrollViewer MaxHeight="180"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Settings.InGameOverlayNeverSuspendGameItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Name}"
                                                                  IsChecked="{Binding IsNeverSuspendEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Margin="0,3,0,3"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <Button Content="{DynamicResource InGameOverlay_NeverSuspendList_Clear}"
                                            Command="{Binding Settings.ClearInGameOverlayNeverSuspendGamesCommand}"
                                            HorizontalAlignment="Left"
                                            Padding="12,6"
                                            Margin="0,2,0,8"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= WARNING / LIMITATIONS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="DarkOrange"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Foreground="DarkOrange"
                                                   Text="{DynamicResource InGameOverlay_Limitations_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource InGameOverlay_Limitations_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource InGameOverlay_Limitations_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>


</UserControl>
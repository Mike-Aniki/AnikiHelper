                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <TextBlock Text="{DynamicResource SteamStore_Enable_Title}"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource SteamStore_Enable_Desc}"
                                   Style="{StaticResource SectionDescription}"
                                   Margin="0,4,0,8"
                                   TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource SteamStore_Enable}"
                                  IsChecked="{Binding Settings.SteamStoreEnabled}"

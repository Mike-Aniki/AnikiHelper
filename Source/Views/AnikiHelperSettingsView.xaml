                                                Margin="10,0,0,6"/>

                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= DYNAMIC COLORS ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource GroupDynColors}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource L_DynAutoPrecache_Title}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Margin="0,4,0,4"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource L_EnableDynamicAutoPrecache_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,4"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource L_EnableDynamicAutoPrecache}"
                                              IsChecked="{Binding Settings.DynamicAutoPrecacheUserEnabled, UpdateSourceTrigger=PropertyChanged}"

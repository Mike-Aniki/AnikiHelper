                                 HorizontalAlignment="Stretch"/>

                                <TextBlock Text="{DynamicResource AnikiNews_SourceA_Url}"
                                   Style="{StaticResource SectionDescription}"
                                   Margin="0,2,0,4"/>

                                <TextBox Text="{Binding Settings.NewsSourceAUrl, UpdateSourceTrigger=PropertyChanged}"

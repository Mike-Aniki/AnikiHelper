            BorderBrush="Transparent"
            BorderThickness="1"
            Background="Transparent"
            Padding="14"
            Margin="0,0,0,5">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource AppTitle}"
                       FontWeight="Bold"
                       FontSize="24"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
                                <Border Background="#2200AEEF"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,6,0,10"
                    MaxWidth="650"
                    HorizontalAlignment="Center">

                                    <TextBlock Text="{DynamicResource AppInfo}"
                           Foreground="White"
                           FontSize="12"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                                </Border>



                            </StackPanel>
                        </Border>

                        <Border Height="1"
            Background="{StaticResource SeparatorBrush}"
            Margin="0,6,0,10"/>

                        <Border Style="{StaticResource SectionCard}">



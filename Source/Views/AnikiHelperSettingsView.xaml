                                    <TextBlock Text="{DynamicResource L_EnableDynamicAutoPrecache_Note}"
                                               Style="{StaticResource SmallNoteText}"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <TextBlock Text="{DynamicResource L_CacheManagement_Title}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Margin="0,0,0,4"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource L_ClearColorCache_Desc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,4"
                                               TextWrapping="Wrap"/>

                                    <Button Content="{DynamicResource L_ClearColorCache}"
                                            Margin="0,4,0,4"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="ClearColorCache_Click"
                                            ToolTip="{DynamicResource L_ClearColorCache_Tooltip}"/>

                                    <TextBlock Text="{DynamicResource DynColors_Help}"
                                               Style="{StaticResource SmallNoteText}"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ========= DEBUG ========= -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource LOCDebugLogsTitle}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource LOCDebugLogsDescription}"
                                               Style="{StaticResource SectionDescription}"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource LOCEnableDebugLogs}"
                                              IsChecked="{Binding Settings.EnableDebugLogs, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource LOCDebugLogsInfo}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"/>

                                    <StackPanel Orientation="Horizontal"
            Margin="0,4,0,0">

                                        <Button Content="{DynamicResource LOCClearLogFile}"
            Click="ClearLogFile_Click"
            Margin="0,0,8,0"/>

                                        <Button Content="{DynamicResource LOCOpenLogsFolder}"
            Click="OpenLogsFolder_Click"/>

                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========= STEAM FEATURES ========= -->
            <TabItem Header="{DynamicResource GroupSteamFeatures}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Margin="0,0,0,16">

                        <!-- Header -->
                        <Border CornerRadius="14"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Background="Transparent"
                                Padding="14"
                                Margin="0,0,0,5">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource AppTitle}"
                                           FontWeight="Bold"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <Border Background="#2200AEEF"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,6,0,10"
                                        MaxWidth="650"
                                        HorizontalAlignment="Center">

                                    <TextBlock Text="{DynamicResource AppInfo}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                </Border>



                            </StackPanel>
                        </Border>

                        <Border Height="1"
                                Background="{StaticResource SeparatorBrush}"
                                Margin="0,6,0,10"/>

                        <!-- STEAM ACCOUNT -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource SteamAccount_GroupTitle}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource SteamAccount_GroupDesc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,0,0,12"
                                               TextWrapping="Wrap"/>

                                    <!-- Steam connection status and actions -->
                                    <Border BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#14FFB000"/>
                                                <Setter Property="BorderBrush" Value="#44FFB000"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                        <Setter Property="Background" Value="#1436D17A"/>
                                                        <Setter Property="BorderBrush" Value="#5536D17A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <Grid Width="28"
                                                  Height="28"
                                                  VerticalAlignment="Top"
                                                  HorizontalAlignment="Left">
                                                <Ellipse>
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#26FFB000"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                    <Setter Property="Fill" Value="#2636D17A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <TextBlock Text="!"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           Foreground="#FFFFB000"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="✓"
                                                           FontFamily="Segoe UI Symbol"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           Foreground="#FF36D17A"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>

                                            <!-- Disconnected state -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,20,0"
                                                        VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <TextBlock Text="{DynamicResource SteamAccount_DisconnectedTitle}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{DynamicResource SteamAccount_DisconnectedDesc}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Settings.SteamAccountStatus}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           Margin="0,5,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- Connected state -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,20,0"
                                                        VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <TextBlock Text="{DynamicResource SteamAccount_ConnectedTitle}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{DynamicResource SteamAccount_ConnectedDesc}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Settings.SteamAccountStatus}"
                                                           Foreground="#FF5BE39A"
                                                           FontSize="11"
                                                           Margin="0,5,0,0"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                                    <TextBlock Text="{DynamicResource SteamAccount_SteamIdLabel}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="11"
                                                               Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Settings.SteamAccountSteamId64}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Actions when disconnected -->
                                            <Grid Grid.Column="2"
                                                  VerticalAlignment="Center">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountBusy}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Opacity" Value="0.55"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Button Content="{DynamicResource SteamAccount_ConnectButton}"
                                                        Command="{Binding Settings.ConnectSteamAccountCommand}"
                                                        Padding="14,7"
                                                        MinWidth="150"/>
                                            </Grid>

                                            <!-- Actions when connected -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountConnected}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Settings.SteamAccountBusy}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Opacity" Value="0.55"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <Button Content="{DynamicResource SteamAccount_CheckButton}"
                                                        Command="{Binding Settings.CheckSteamAccountCommand}"
                                                        Padding="12,6"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="{DynamicResource SteamAccount_DisconnectButton}"
                                                        Command="{Binding Settings.DisconnectSteamAccountCommand}"
                                                        Padding="12,6"
                                                        Foreground="#FFFF8A8A"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Steam configuration -->
                                    <Grid>
                                        <!-- Web API key -->
                                        <Border
                                                Background="#0DFFFFFF"
                                                BorderBrush="#20FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{DynamicResource SteamAccount_ApiKeyTitle}"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>

                                                    <Grid Grid.Column="1" Margin="10,0,0,0">
                                                        <!-- API key configured badge -->
                                                        <Border Background="#2036D17A"
                                                                BorderBrush="#5536D17A"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Settings.SteamApiKey}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Settings.SteamApiKey}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{DynamicResource SteamAccount_ConfiguredBadge}"
                                                                       Foreground="#FF5BE39A"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>

                                                        <!-- API key missing badge -->
                                                        <Border Background="#20FFB000"
                                                                BorderBrush="#55FFB000"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Settings.SteamApiKey}" Value="">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Settings.SteamApiKey}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{DynamicResource SteamAccount_MissingBadge}"
                                                                       Foreground="#FFFFC247"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                </Grid>

                                                <TextBlock Text="{DynamicResource SteamAccount_ApiKeyDesc}"
                                                           Style="{StaticResource SmallNoteText}"
                                                           Margin="0,0,0,8"
                                                           TextWrapping="Wrap"/>

                                                <PasswordBox x:Name="SteamApiKeyPasswordBox"
                                                             PasswordChanged="SteamApiKeyPasswordBox_PasswordChanged"
                                                             PasswordChar="●"
                                                             HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>

                                    <!-- Steam Friends privacy requirement -->
                                    <Border Background="#0FFFB000"
                                            BorderBrush="#33FFB000"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8"
                                            Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="i"
                                                       FontWeight="Bold"
                                                       Foreground="#FFFFC247"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{DynamicResource SteamAccount_PrivacyNotice}"
                                                       Style="{StaticResource SmallNoteText}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- STEAM UPDATES -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource SteamUpdates_GroupTitle}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource SteamUpdates_GroupDesc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource SteamUpdates_Enable}"
                                              IsChecked="{Binding Settings.SteamUpdatesScanEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource SteamUpdates_Enable_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <TextBlock Text="{DynamicResource SteamInitCache_ProgressTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource SteamInitCache_ProgressDesc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,2,0,6">
                                        <Button Content="{DynamicResource SteamInitCache}"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="InitializeSteamCache_Click"
                                                ToolTip="{DynamicResource SteamInitCache_Tooltip}"/>

                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{DynamicResource LOCSteamLastScan}"
                                                       Style="{StaticResource SmallNoteText}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Settings.LastSteamRecentCheckDisplay}"
                                                       Style="{StaticResource SmallNoteText}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="{DynamicResource SteamInitCache_ProgressNote}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CURRENT PLAYERS -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource SteamPlayers_GroupTitle}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource SteamPlayers_GroupDesc}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource SteamPlayers_Enable}"
                                              IsChecked="{Binding Settings.SteamPlayerCountEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource SteamPlayers_Help}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>


                        <!-- STEAM FRIENDS -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>

                                <Border Style="{StaticResource SectionHeaderBar}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{StaticResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,8,2"/>

                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SectionHeaderTitle}"
                                                   Text="{DynamicResource LOCSteamFriends_Title}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="12,10,12,12">

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_Subtitle}"
                                               Style="{StaticResource SectionDescription}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource LOCSteamFriends_Enable}"
                                              IsChecked="{Binding Settings.SteamFriendsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_EnableHelp}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_Display}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_OnlineInfo}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource LOCSteamFriends_ShowOffline}"
                                              IsChecked="{Binding Settings.ShowOffline, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,4"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_OfflineInfo}"
                                               Style="{StaticResource SmallNoteText}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap"/>

                                    <Border Style="{StaticResource SectionSeparator}"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_Notifications}"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextWrapping="Wrap"/>

                                    <CheckBox Content="{DynamicResource LOCSteamFriends_NotifyOnGameStart}"
                                              IsChecked="{Binding Settings.NotifyOnGameStart, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,8,0,4"/>

                                    <TextBlock Text="{DynamicResource LOCSteamFriends_NotifyOnGameStartHelp}"

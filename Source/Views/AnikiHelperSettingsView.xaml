                                   Margin="0,2,0,4"/>

                                <TextBox Text="{Binding Settings.NewsSourceBTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"
                                 HorizontalAlignment="Stretch"/>

                                <TextBlock Text="{DynamicResource AnikiNews_SourceB_Url}"
                                   Style="{StaticResource SectionDescription}"
                                   Margin="0,2,0,4"/>

                                <TextBox Text="{Binding Settings.NewsSourceBUrl, UpdateSourceTrigger=PropertyChanged}"

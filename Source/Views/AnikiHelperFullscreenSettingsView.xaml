<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:pctrls="clr-namespace:Playnite.FullscreenApp.Controls;assembly=Playnite.FullscreenApp"
             KeyboardNavigation.TabNavigation="Cycle"
             KeyboardNavigation.DirectionalNavigation="Cycle">

    <ScrollViewer Style="{DynamicResource AnikiHelperSettingsScrollViewerStyle}">
        <StackPanel Margin="40,20,40,40"
                    KeyboardNavigation.TabNavigation="Cycle"
                    KeyboardNavigation.DirectionalNavigation="Cycle">

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,40"
                        Style="{DynamicResource AnikiHelperSettingsSectionHeaderStyle}">

                <DockPanel Style="{DynamicResource AnikiHelperSettingsHeaderDockPanelStyle}">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               Style="{DynamicResource TextAnikiHelperSettingsStyle}" />
                </DockPanel>

                <TextBlock Text="{DynamicResource MoreOptionsDesktop}"
                           Style="{DynamicResource TextAnikiHelperSettingsStyleSousTitre}" />

                <Border Style="{DynamicResource AnikiHelperSettingsSectionSeparatorStyle}"/>
            </StackPanel>

            <pctrls:CheckBoxEx Content="{DynamicResource WelcomeHubStartup_Enable}"
                               IsChecked="{Binding Settings.OpenWelcomeHubOnStartup}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource WelcomeHubStartup_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource EventSounds_Enable}"
                               IsChecked="{Binding Settings.EventSoundsEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource EventSounds_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource NewsScan_Enable}"
                               IsChecked="{Binding Settings.NewsScanEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource NewsScan_Enable_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource IncludeHidden}"
                               IsChecked="{Binding Settings.IncludeHidden}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource StatsHelp}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />



            <!-- VIDEO -->
            <StackPanel Style="{DynamicResource AnikiHelperSettingsSectionHeaderStyle}">
                <TextBlock Text="{DynamicResource Video}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleSectionStyle}"
                           HorizontalAlignment="Center"/>

                <Border Style="{DynamicResource AnikiHelperSettingsSectionSeparatorStyle}"/>
            </StackPanel>

            <pctrls:CheckBoxEx Content="{DynamicResource StartupIntro_Enable}"
                               IsChecked="{Binding Settings.StartupIntroVideoEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource IntroVideo_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource ShutdownVideo_Enable}"
                               IsChecked="{Binding Settings.ShutdownVideoEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource ShutdownVideo_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />


            <!-- STEAM -->
            <StackPanel Style="{DynamicResource AnikiHelperSettingsSectionHeaderStyle}">
                <TextBlock Text="{DynamicResource GroupSteamFeatures}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleSectionStyle}"
                           HorizontalAlignment="Center"/>

                <Border Style="{DynamicResource AnikiHelperSettingsSectionSeparatorStyle}"/>
            </StackPanel>

            <pctrls:CheckBoxEx Content="{DynamicResource SteamUpdates_Enable}"
                               IsChecked="{Binding Settings.SteamUpdatesScanEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource SteamUpdates_Enable_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource SteamPlayers_Enable}"
                               IsChecked="{Binding Settings.SteamPlayerCountEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource SteamPlayers_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource SteamStore_Enable}"
                               IsChecked="{Binding Settings.SteamStoreEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource SteamStore_Enable_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <Grid Margin="10,30,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource SteamStore_Language_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <pctrls:ComboBoxEx Grid.Column="1"
                                   SelectedValue="{Binding Settings.SteamStoreLanguage, UpdateSourceTrigger=PropertyChanged}"
                                   SelectedValuePath="Tag"
                                   Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">
                    <ComboBoxItem Content="English" Tag="english"/>
                    <ComboBoxItem Content="French" Tag="french"/>
                    <ComboBoxItem Content="German" Tag="german"/>
                    <ComboBoxItem Content="Spanish" Tag="spanish"/>
                    <ComboBoxItem Content="Italian" Tag="italian"/>
                    <ComboBoxItem Content="Portuguese" Tag="portuguese"/>
                    <ComboBoxItem Content="Brazilian Portuguese" Tag="brazilian"/>
                    <ComboBoxItem Content="Russian" Tag="russian"/>
                    <ComboBoxItem Content="Polish" Tag="polish"/>
                    <ComboBoxItem Content="Czech" Tag="czech"/>
                    <ComboBoxItem Content="Japanese" Tag="japanese"/>
                    <ComboBoxItem Content="Korean" Tag="koreana"/>
                    <ComboBoxItem Content="Simplified Chinese" Tag="schinese"/>
                    <ComboBoxItem Content="Traditional Chinese" Tag="tchinese"/>
                </pctrls:ComboBoxEx>
            </Grid>

            <TextBlock Text="{DynamicResource SteamStore_Language_Desc}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <Grid Margin="10,30,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource SteamStore_Country_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <pctrls:ComboBoxEx Grid.Column="1"
                                   SelectedValue="{Binding Settings.SteamStoreRegion, UpdateSourceTrigger=PropertyChanged}"
                                   SelectedValuePath="Tag"
                                   Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">
                    <ComboBoxItem Content="United States (USD)" Tag="US"/>
                    <ComboBoxItem Content="France (EUR)" Tag="FR"/>
                    <ComboBoxItem Content="Belgium (EUR)" Tag="BE"/>
                    <ComboBoxItem Content="Germany (EUR)" Tag="DE"/>
                    <ComboBoxItem Content="Spain (EUR)" Tag="ES"/>
                    <ComboBoxItem Content="Italy (EUR)" Tag="IT"/>
                    <ComboBoxItem Content="United Kingdom (GBP)" Tag="GB"/>
                    <ComboBoxItem Content="Canada (CAD)" Tag="CA"/>
                    <ComboBoxItem Content="Japan (JPY)" Tag="JP"/>
                    <ComboBoxItem Content="Brazil (BRL)" Tag="BR"/>
                    <ComboBoxItem Content="Poland (PLN)" Tag="PL"/>
                    <ComboBoxItem Content="Russia" Tag="RU"/>
                </pctrls:ComboBoxEx>
            </Grid>

            <TextBlock Text="{DynamicResource SteamStore_Country_Desc}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <!-- SPLASH SCREEN -->
            <StackPanel Style="{DynamicResource AnikiHelperSettingsSectionHeaderStyle}">
                <TextBlock Text="{DynamicResource GameLaunchSplash_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleSectionStyle}"
                           HorizontalAlignment="Center"/>

                <Border Style="{DynamicResource AnikiHelperSettingsSectionSeparatorStyle}"/>
            </StackPanel>

            <pctrls:CheckBoxEx Content="{DynamicResource GameLaunchSplash_Enable}"
                               IsChecked="{Binding Settings.GameLaunchSplashEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource GameLaunchSplash_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <Grid Margin="10,20,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GameLaunchSplash_Mode_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <pctrls:ComboBoxEx Grid.Column="1"
                                   SelectedValue="{Binding Settings.GameLaunchSplashSelectionMode, UpdateSourceTrigger=PropertyChanged}"
                                   SelectedValuePath="Tag"
                                   Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_Mode_Automatic}" Tag="Automatic"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_Mode_CustomPriority}" Tag="CustomPriority"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_Mode_AlwaysSource}" Tag="AlwaysSource"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_Mode_AlwaysPlatform}" Tag="AlwaysPlatform"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_Mode_AlwaysGlobal}" Tag="AlwaysGlobal"/>
                </pctrls:ComboBoxEx>
            </Grid>

            <TextBlock Text="{DynamicResource GameLaunchSplash_Mode_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource GameLaunchSplash_ShowLogo}"
                               IsChecked="{Binding Settings.GameLaunchSplashShowLogo}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <Grid Margin="10,20,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GameLaunchSplash_LogoPosition_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <pctrls:ComboBoxEx Grid.Column="1"
                                   SelectedValue="{Binding Settings.GameLaunchSplashLogoPosition, UpdateSourceTrigger=PropertyChanged}"
                                   SelectedValuePath="Tag"
                                   Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_LeftTop}" Tag="LeftTop"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_LeftCenter}" Tag="LeftCenter"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_LeftBottom}" Tag="LeftBottom"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_CenterTop}" Tag="CenterTop"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_Center}" Tag="Center"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_CenterBottom}" Tag="CenterBottom"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_RightTop}" Tag="RightTop"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_RightCenter}" Tag="RightCenter"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_LogoPosition_RightBottom}" Tag="RightBottom"/>
                </pctrls:ComboBoxEx>
            </Grid>

            <TextBlock Text="{DynamicResource GameLaunchSplash_LogoPosition_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <Grid Margin="10,20,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GameLaunchSplash_MinDuration_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <pctrls:ComboBoxEx Width="260"
                                       SelectedValue="{Binding Settings.GameLaunchSplashMinimumDurationMs, UpdateSourceTrigger=PropertyChanged}"
                                       SelectedValuePath="Tag"
                                       Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">

                        <ComboBoxItem Content="1 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>1000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="2.4 sec (Default)">
                            <ComboBoxItem.Tag>
                                <sys:Int32>2400</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="3 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>3000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="5 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>5000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="7 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>7000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="10 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>10000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="15 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>15000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="30 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>30000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="45 sec">
                            <ComboBoxItem.Tag>
                                <sys:Int32>45000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="1 min">
                            <ComboBoxItem.Tag>
                                <sys:Int32>60000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="2 min">
                            <ComboBoxItem.Tag>
                                <sys:Int32>120000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="5 min">
                            <ComboBoxItem.Tag>
                                <sys:Int32>300000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>

                        <ComboBoxItem Content="10 min">
                            <ComboBoxItem.Tag>
                                <sys:Int32>600000</sys:Int32>
                            </ComboBoxItem.Tag>
                        </ComboBoxItem>
                    </pctrls:ComboBoxEx>

                    <TextBlock Text="{Binding Settings.GameLaunchSplashMinimumDurationDisplay}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="18"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{DynamicResource GameLaunchSplash_MinDuration_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />



            <Grid Margin="10,20,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GameLaunchSplash_VideoEndBehavior_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <pctrls:ComboBoxEx Grid.Column="1"
                                   SelectedValue="{Binding Settings.GameLaunchSplashVideoEndBehavior, UpdateSourceTrigger=PropertyChanged}"
                                   SelectedValuePath="Tag"
                                   Style="{DynamicResource AnikiHelperSettingsComboBoxStyle}">
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_VideoEndBehavior_ShowGameBackground}" Tag="ShowGameBackground"/>
                    <ComboBoxItem Content="{DynamicResource GameLaunchSplash_VideoEndBehavior_KeepLastFrame}" Tag="KeepLastFrame"/>
                </pctrls:ComboBoxEx>
            </Grid>

            <TextBlock Text="{DynamicResource GameLaunchSplash_VideoEndBehavior_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <pctrls:CheckBoxEx Content="{DynamicResource GameLaunchSplash_VideoSound_Enable}"
                               IsChecked="{Binding Settings.GameLaunchSplashVideoSoundEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource GameLaunchSplash_VideoSound_Help}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

            <Grid Margin="10,20,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource GameLaunchSplash_VideoVolume_Title}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleOptionComboBoxStyle}"
                           Margin="0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Slider Minimum="0"
                            Maximum="1"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Width="300"
                            Style="{DynamicResource AnikiHelperSettingsSliderStyle}"
                            Value="{Binding Settings.GameLaunchSplashVideoVolume, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="{Binding Settings.GameLaunchSplashVideoVolume, StringFormat={}{0:P0}}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="18"/>
                </StackPanel>
            </Grid>




            <!-- DYNAMIC COLORS -->
            <StackPanel Style="{DynamicResource AnikiHelperSettingsSectionHeaderStyle}">
                <TextBlock Text="{DynamicResource GroupDynamicColors}"
                           Style="{DynamicResource AnikiHelperSettingsSectionTitleSectionStyle}"
                           HorizontalAlignment="Center"/>

                <Border Style="{DynamicResource AnikiHelperSettingsSectionSeparatorStyle}"/>
            </StackPanel>

            <pctrls:CheckBoxEx Content="{DynamicResource L_EnableDynamicAutoPrecache}"
                               IsChecked="{Binding Settings.DynamicAutoPrecacheUserEnabled}"
                               Style="{DynamicResource AnikiHelperSettingsCheckBoxStyle}"/>

            <TextBlock Text="{DynamicResource L_EnableDynamicAutoPrecache_Note}"
                       Style="{DynamicResource TextAnikiHelperSettingsStyleMini}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
    <sys:String x:Key="AnikiNews_CustomFeed_Exemple2">Actu Gaming : https://actugaming.net/feed</sys:String>
    <sys:String x:Key="AnikiNews_CustomFeed_Exemple3">JVFrance: https://www.jvfrance.com/feed</sys:String>
    <sys:String x:Key="AnikiNews_CustomFeed_Exemple4">Cowcotland : https://feeds.feedburner.com/cowcotland</sys:String>
    <sys:String x:Key="AnikiNews_CustomFeed_Exemple5">Steam News : https://store.steampowered.com/feeds/news/collection/featured</sys:String>

</ResourceDictionary>
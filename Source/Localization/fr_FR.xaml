    <!-- Update data -->
    <sys:String x:Key="SteamInitCache_ProgressTitle">Données de mise à jour</sys:String>
    <sys:String x:Key="SteamInitCache_ProgressDesc">Le plugin vérifie les mises à jour Steam des jeux pendant la navigation. Vous pouvez lancer une analyse complète de votre bibliothèque pour remplir les données de tous vos jeux sans attendre de les parcourir un par un. Cela évite les fausses notifications et améliore les performances.</sys:String>

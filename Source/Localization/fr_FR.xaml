    <sys:String x:Key="AnikiNews_CustomFeed_Desc2">Vous pouvez utiliser les sources par défaut ou définir les vôtres. Si un flux est vide ou invalide, les sources par défaut seront utilisées automatiquement.</sys:String>
    <sys:String x:Key="AnikiNews_CustomFeed_Help">Optionnel : entrez une URL de flux RSS personnalisée.</sys:String>
    <sys:String x:Key="AnikiNews_CustomFeed_Tooltip">Remplace le flux par défaut.</sys:String>

    <!-- GLOBAL CACHE -->
    <sys:String x:Key="AnikiNews_ClearCache">Réinitialiser le cache des actualités</sys:String>
    <sys:String x:Key="AnikiNews_ClearCache_Tooltip">Force le rechargement des actualités.</sys:String>
    <sys:String x:Key="AnikiNews_ClearCache_Note">Inutile après un changement d’URL : l’actualisation est automatique.</sys:String>
    <sys:String x:Key="AnikiNews_ClearCache_Confirm">Réinitialiser le cache des actualités ?</sys:String>
    <sys:String x:Key="AnikiNews_ClearCache_Done">Les actualités ont été actualisées.</sys:String>

    <!-- ENABLE -->
    <sys:String x:Key="NewsScan_Enable">Activer les actualités</sys:String>
    <sys:String x:Key="NewsScan_Enable_Help">Désactive complètement le chargement des actualités lorsque l’option est désactivée.</sys:String>
    <sys:String x:Key="NewsScan_Desc">Active ou désactive la fonction d’actualités.</sys:String>

    <!-- EXPLANATIONS -->
    <sys:String x:Key="AnikiNews_CustomFeed_Help2">Informations supplémentaires</sys:String>

    <sys:String x:Key="NewsScan_Enable_Help2_Line1">Si le champ URL est vide, un flux par défaut est utilisé automatiquement.</sys:String>
    <sys:String x:Key="NewsScan_Enable_Help2_Line2">Si vous modifiez l’URL, le cache est actualisé automatiquement.</sys:String>
    <sys:String x:Key="NewsScan_Enable_Help2_Line3">Vous n’avez pas besoin de vider le cache après avoir changé l’URL.</sys:String>
    <sys:String x:Key="NewsScan_Enable_Help2_Line4">Le bouton de cache est utile uniquement si le chargement ne fonctionne plus correctement.</sys:String>
    <sys:String x:Key="NewsScan_Enable_Help2_Line5">Certains flux RSS peuvent ne pas être compatibles.</sys:String>


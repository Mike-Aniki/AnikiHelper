    <!-- ========= ACHIEVEMENTS CACHE ========= -->
    <sys:String x:Key="AchievementCache_Title">Cache des souvenirs de trophées</sys:String>
    <sys:String x:Key="AchievementCache_Desc">Reconstruit les souvenirs de trophées à partir de PlayniteAchievements. À utiliser si les icônes, les derniers trophées ou les données de rareté sont manquants ou obsolètes.</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild">Souvenirs de trophées</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Button">Reconstruire le cache</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Help">Analyse PlayniteAchievements et reconstruit les souvenirs de trophées affichés dans le Theme. Cela peut prendre du temps sur les grandes bibliothèques.</sys:String>
    <sys:String x:Key="AchievementCache_Status_Scanning">Analyse des trophées...</sys:String>
    <sys:String x:Key="AchievementCache_Status_Done">Cache des souvenirs de trophées reconstruit : {0} éléments.</sys:String>
    <sys:String x:Key="AchievementCache_Status_Failed">Échec de la reconstruction du cache des souvenirs de trophées.</sys:String>
    <sys:String x:Key="LOCAnikiHelperRefreshAchievementCacheForGame">Rafraîchir les souvenirs de ce jeu</sys:String>
    <!-- ========= CUSTOM ICONS ========= -->
    <sys:String x:Key="CustomIcons_Title">Icônes personnalisées</sys:String>
    <sys:String x:Key="CustomIcons_Desc">Choisissez des dossiers externes pour les icônes de filtres, les icônes de sources et les images de bannières. Ces fichiers remplacent ceux du thème sans modifier les fichiers du thème.</sys:String>
    <sys:String x:Key="CustomIcons_FilterFolder">Dossier des icônes de filtres</sys:String>
    <sys:String x:Key="CustomIcons_SourceFolder">Dossier des icônes de sources</sys:String>
    <sys:String x:Key="CustomIcons_BannerAboveCoverFolder">Dossier des bannières au-dessus des jaquettes</sys:String>
    <sys:String x:Key="CustomIcons_BannerOnCoverFolder">Dossier des bannières sur les jaquettes</sys:String>
    <sys:String x:Key="CustomIcons_Help">Les fichiers PNG doivent utiliser exactement les mêmes noms que les filtres, sources ou plateformes affichés dans Playnite. Exemples : Installed.png, Favorites.png, Steam.png. Utilisez deux dossiers séparés pour les bannières au-dessus des jaquettes et les bannières sur les jaquettes.</sys:String>
    <sys:String x:Key="BrowseFolder">Parcourir...</sys:String>
    <sys:String x:Key="CustomIcons_SelectFilterFolderDialog">Sélectionnez le dossier contenant vos icônes PNG de filtres.</sys:String>
    <sys:String x:Key="CustomIcons_SelectSourceFolderDialog">Sélectionnez le dossier contenant vos icônes PNG de sources.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerAboveCoverFolderDialog">Sélectionnez le dossier contenant vos bannières PNG au-dessus des jaquettes.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerOnCoverFolderDialog">Sélectionnez le dossier contenant vos bannières PNG sur les jaquettes.</sys:String>

    <!-- ========= TRACK PLAYTIME FEATURES ========= -->
    <sys:String x:Key="GroupMonthly">Historique mensuel</sys:String>
    <sys:String x:Key="ResetSectionTitle">Réinitialiser le suivi du mois en cours</sys:String>
    <sys:String x:Key="BackupSectionTitle">Sauvegarder et restaurer votre historique</sys:String>

    <sys:String x:Key="MonthlyHelp">Suit votre temps de jeu chaque mois afin que le thème puisse afficher des statistiques comme le temps de jeu du mois, le nombre de jeux joués et votre jeu le plus joué.</sys:String>
    <sys:String x:Key="CurrentMonthData">Mois en cours :</sys:String>
    <sys:String x:Key="SnapshotTooltip">Affiche le moment où le suivi du mois en cours a commencé.</sys:String>

    <sys:String x:Key="ResetWarningText">Attention : cela supprime les données de suivi du mois en cours.</sys:String>
    <sys:String x:Key="ResetBtn">Réinitialiser le suivi du mois en cours</sys:String>
    <sys:String x:Key="ResetBtnTooltip">Supprime les données de suivi du mois en cours et redémarre le suivi à partir de maintenant.</sys:String>
    <sys:String x:Key="ResetBtntip">N’utilisez pas ce bouton sauf si vous voulez vraiment effacer le suivi du mois actuel. Les statistiques mensuelles du mois en cours repartiront de zéro après la réinitialisation.</sys:String>

    <sys:String x:Key="ExportMonthlyBackupBtn">Exporter l’historique</sys:String>
    <sys:String x:Key="ImportMonthlyBackupBtn">Importer l’historique</sys:String>
    <sys:String x:Key="ExportMonthlyBackupTooltip">Exporte toutes les données de suivi mensuel dans un fichier de sauvegarde.</sys:String>
    <sys:String x:Key="ImportMonthlyBackupTooltip">Importe une sauvegarde précédemment enregistrée du suivi mensuel.</sys:String>
    <sys:String x:Key="MonthlyBackupHelp">Utilisez ces boutons pour sauvegarder ou restaurer toutes les données de suivi mensuel. C’est utile avant de réinstaller Playnite ou de réinitialiser votre bibliothèque.</sys:String>

    <!-- ========= VIDEO FEATURES ========= -->
    <sys:String x:Key="Video">Vidéo</sys:String>

    <sys:String x:Key="StartupIntro_Title">Vidéo d’introduction</sys:String>
    <sys:String x:Key="StartupIntro_Desc">Joue une vidéo d’introduction au lancement de Playnite.</sys:String>
    <sys:String x:Key="StartupIntro_Enable">Activer la vidéo d’introduction</sys:String>
    <sys:String x:Key="IntroVideo_Help">Désactivez cette option pour lancer Playnite sans la vidéo d’introduction.</sys:String>

    <sys:String x:Key="ShutdownVideo_Title">Vidéo de fermeture</sys:String>
    <sys:String x:Key="ShutdownVideo_Desc">Joue une vidéo de fermeture lors de la fermeture de Playnite.</sys:String>
    <sys:String x:Key="ShutdownVideo_Enable">Activer la vidéo de fermeture</sys:String>
    <sys:String x:Key="ShutdownVideo_Help">Désactivez cette option pour fermer Playnite sans la vidéo de fermeture.</sys:String>

    <!-- ========= SOUND FEATURES ========= -->
    <sys:String x:Key="EventSounds_Title">Sons d’événements</sys:String>
    <sys:String x:Key="EventSounds_Desc">Joue des effets sonores lors d’événements comme le lancement de jeux, l’ouverture/fermeture de Playnite ou les mises à jour de la bibliothèque. Fonctionne avec les sons inclus dans le thème.</sys:String>
    <sys:String x:Key="EventSounds_Enable">Activer les sons d’événements</sys:String>
    <sys:String x:Key="EventSounds_Help">Si activé, désactivez les sons UI/événements du plugin PlayniteSounds pour éviter les doublons.</sys:String>

    <!-- ========= GameOverlay FEATURES ========= -->
    <sys:String x:Key="InGameOverlay_Tab">Overlay en jeu</sys:String>
    <sys:String x:Key="InGameOverlay_Title">Overlay en jeu</sys:String>
    <sys:String x:Key="InGameOverlay_Desc">Affiche un panneau d’actions rapides Aniki au-dessus du jeu en cours.</sys:String>

    <sys:String x:Key="InGameOverlay_Settings_Title">Réglages de l’overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Settings_Desc">Configure l’overlay en jeu d’Aniki et son raccourci clavier.</sys:String>

    <sys:String x:Key="InGameOverlay_Enable">Activer l’overlay en jeu</sys:String>
    <sys:String x:Key="InGameOverlay_Enable_Help">Active l’overlay en jeu propre à Aniki Helper. Désactive cette option si tu préfères utiliser l’overlay de Playnite ou une autre solution d’overlay.</sys:String>

    <sys:String x:Key="InGameOverlay_Hotkey_Title">Raccourci de l’overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Hotkey_Help">Choisis le raccourci clavier utilisé pour ouvrir l’overlay en jeu. Redémarre Playnite après avoir modifié ce réglage.</sys:String>

    <sys:String x:Key="InGameOverlay_ControllerShortcut_Title">Raccourci manette</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Help">Choisis le raccourci manette utilisé pour ouvrir l’overlay en jeu. Le bouton Guide est expérimental et peut être capturé par Steam, Windows ou certains outils manette.</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_StartBack">Start + Select</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_BackY">Select + Y</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Guide">Bouton Guide</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Disabled">Désactivé</sys:String>

    <sys:String x:Key="InGameOverlay_GameBehavior_Title">Comportement du jeu quand l’overlay est ouvert</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_DoNothing">Par défaut : ne rien faire</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_SuspendGame">Expérimental : suspendre le jeu quand l’overlay est ouvert</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Help">Choisis si Aniki Helper doit laisser le jeu tourner normalement ou figer temporairement le processus du jeu pendant que l’overlay est ouvert pour éviter les doubles inputs.</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Warning">Attention : déconseillé pour les jeux en ligne, multijoueur, protégés par anti-cheat ou lancés en administrateur.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Title">Jeux à ne jamais suspendre</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Help">Les jeux ajoutés depuis clic droit → Aniki Helper → Overlay Settings → Never suspend this game apparaissent ici. Décoche un jeu pour le retirer de la liste.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Clear">Vider la liste</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayNeverSuspendThisGame">Never suspend this game</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayAllowSuspendThisGame">Allow suspend for this game</sys:String>

    <sys:String x:Key="InGameOverlay_Limitations_Title">Limitation</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Desc">Cet overlay est une fenêtre transparente affichée au-dessus du jeu. Il n’est pas injecté directement dans le jeu comme les overlays Steam ou Discord.</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Help">Il fonctionne mieux avec les jeux en mode fenêtré sans bordure ou plein écran fenêtré. Certains jeux en plein écran exclusif, certains anti-cheats ou certains jeux lancés en administrateur peuvent empêcher l’overlay de s’afficher correctement.</sys:String>
    <sys:String x:Key="LOCInGameOverlayFooterTitle">Aniki Control Center</sys:String>
    <sys:String x:Key="LOCInGameOverlayNoGameRunning">Aucun jeu lancé</sys:String>
    <sys:String x:Key="LOCInGameOverlayNoActiveGame">Aucun jeu actif détecté</sys:String>
    <sys:String x:Key="LOCInGameOverlayLessThanOneMinute">moins de 1 min</sys:String>

    <!-- Steam Friends -->
    <sys:String x:Key="LOCSteamFriends_Title">Steam Friends</sys:String>
    <sys:String x:Key="LOCSteamFriends_Subtitle">Affiche le statut de vos amis Steam dans le thème Aniki : amis en ligne, jeux en cours, profils et notifications intégrées au thème.</sys:String>

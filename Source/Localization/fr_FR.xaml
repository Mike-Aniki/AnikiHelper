    <!-- ========= MEDIA GALLERY ========= -->

    <sys:String x:Key="MediaGallery_Title">Galerie média</sys:String>
    <sys:String x:Key="MediaGallery_Desc">Aniki Helper lit les médias depuis Screenshots Visualizer et Screenshot Utilities. Configurez vos dossiers de captures dans ces plugins ; Aniki Helper lit uniquement leurs données et génère des miniatures pour accélérer la navigation dans le thème.</sys:String>

    <sys:String x:Key="MediaGallery_Provider_Title">Plugin de captures</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Visualizer">Screenshots Visualizer</sys:String>
    <sys:String x:Key="MediaGallery_Provider_UtilitiesLocal">Screenshot Utilities - Local</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Help">Le thème utilisera la liste média d’Aniki Helper au lieu de se lier directement au plugin de captures sélectionné.</sys:String>

    <sys:String x:Key="MediaGallery_GenerateThumbnails">Miniatures média</sys:String>
    <sys:String x:Key="MediaGallery_GenerateThumbnails_Button">Générer les miniatures</sys:String>
    <sys:String x:Key="MediaGallery_GenerateThumbnails_Help">Pré-génère les miniatures de toutes les images des plugins de captures. La première génération peut prendre du temps, mais les suivantes devraient être plus rapides.</sys:String>

    <sys:String x:Key="MediaGallery_Status_WindowTitle">Générer les miniatures</sys:String>
    <sys:String x:Key="MediaGallery_Status_Scanning">Analyse des fichiers média...</sys:String>

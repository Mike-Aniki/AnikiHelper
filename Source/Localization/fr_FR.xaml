    <!-- ========= SPLASH FEATURES ========= -->
    <sys:String x:Key="SplashScreen">Splash screen</sys:String>
    <sys:String x:Key="GameLaunchSplash_Title">Image de lancement des jeux</sys:String>
    <sys:String x:Key="GameLaunchSplash_Desc">Affiche une image ou une vidéo de lancement lorsqu’un jeu démarre. Vous pouvez gérer les splashs personnalisés depuis le clic droit sur un jeu.</sys:String>

    <sys:String x:Key="MediaGallery_Title">Media Gallery</sys:String>
    <sys:String x:Key="MediaGallery_Desc">Aniki Helper reads media from Screenshots Visualizer and Screenshot Utilities. Configure your screenshot folders in those plugins; Aniki Helper only reads their data and generates thumbnails to speed up navigation in the theme.</sys:String>


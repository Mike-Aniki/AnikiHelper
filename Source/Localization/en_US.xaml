    <sys:String x:Key="AchievementCache_Status_Done">Achievement memories cache rebuilt: {0} items.</sys:String>
    <sys:String x:Key="AchievementCache_Status_Failed">Failed to rebuild the achievement memories cache.</sys:String>
    <sys:String x:Key="LOCAnikiHelperRefreshAchievementCacheForGame">Refresh this game's memories</sys:String>
    <!-- ========= CUSTOM ICONS ========= -->
    <sys:String x:Key="CustomIcons_Title">Custom icons</sys:String>
    <sys:String x:Key="CustomIcons_Desc">Choose external folders for custom filter, source, and banner images. These files override the default theme visuals without modifying the theme files.</sys:String>
    <sys:String x:Key="CustomIcons_FilterFolder">Filter icons folder</sys:String>
    <sys:String x:Key="CustomIcons_SourceFolder">Source icons folder</sys:String>
    <sys:String x:Key="CustomIcons_BannerAboveCoverFolder">Banner above cover folder</sys:String>
    <sys:String x:Key="CustomIcons_BannerOnCoverFolder">Banner on cover folder</sys:String>
    <sys:String x:Key="CustomIcons_Help">PNG files must use the exact same names as the filters, sources, or platforms shown in Playnite. Examples: Installed.png, Favorites.png, Steam.png. Use separate folders for above-cover banners and on-cover banners.</sys:String>
    <sys:String x:Key="BrowseFolder">Browse...</sys:String>
    <sys:String x:Key="CustomIcons_SelectFilterFolderDialog">Select the folder containing your filter PNG icons.</sys:String>
    <sys:String x:Key="CustomIcons_SelectSourceFolderDialog">Select the folder containing your source PNG icons.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerAboveCoverFolderDialog">Select the folder containing your above-cover banner PNG images.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerOnCoverFolderDialog">Select the folder containing your on-cover banner PNG images.</sys:String>

    <!-- ========= TRACK PLAYTIME FEATURES ========= -->
    <sys:String x:Key="GroupMonthly">Monthly history</sys:String>
    <sys:String x:Key="ResetSectionTitle">Reset current month tracking</sys:String>
    <sys:String x:Key="BackupSectionTitle">Save and restore your history</sys:String>

    <sys:String x:Key="MonthlyHelp">Tracks your playtime each month so the theme can show stats such as playtime this month, games played, and your most played game.</sys:String>
    <sys:String x:Key="CurrentMonthData">Current month:</sys:String>
    <sys:String x:Key="SnapshotTooltip">Shows when tracking for the current month started.</sys:String>

    <sys:String x:Key="ResetWarningText">Warning: this deletes the current month tracking data.</sys:String>
    <sys:String x:Key="ResetBtn">Reset current month tracking</sys:String>
    <sys:String x:Key="ResetBtnTooltip">Deletes the current month tracking data and starts again from now.</sys:String>
    <sys:String x:Key="ResetBtntip">Do not use this unless you really want to erase this month’s tracking. Monthly stats for the current month will restart from zero after reset.</sys:String>

    <sys:String x:Key="ExportMonthlyBackupBtn">Export history</sys:String>
    <sys:String x:Key="ImportMonthlyBackupBtn">Import history</sys:String>
    <sys:String x:Key="ExportMonthlyBackupTooltip">Exports all monthly tracking data to a backup file.</sys:String>
    <sys:String x:Key="ImportMonthlyBackupTooltip">Imports a previously saved monthly tracking backup.</sys:String>
    <sys:String x:Key="MonthlyBackupHelp">Use these buttons to back up or restore all monthly tracking data. This is useful before reinstalling Playnite or resetting your library.</sys:String>

    <!-- ========= VIDEO FEATURES ========= -->
    <sys:String x:Key="Video">Video</sys:String>

    <sys:String x:Key="StartupIntro_Title">Startup intro video</sys:String>
    <sys:String x:Key="StartupIntro_Desc">Plays an intro video when Playnite starts.</sys:String>
    <sys:String x:Key="StartupIntro_Enable">Enable startup intro video</sys:String>
    <sys:String x:Key="IntroVideo_Help">Disable this to start Playnite without the intro video.</sys:String>

    <sys:String x:Key="ShutdownVideo_Title">Shutdown video</sys:String>
    <sys:String x:Key="ShutdownVideo_Desc">Plays a closing video when Playnite shuts down.</sys:String>
    <sys:String x:Key="ShutdownVideo_Enable">Enable shutdown video</sys:String>
    <sys:String x:Key="ShutdownVideo_Help">Disable this to close Playnite without the shutdown video.</sys:String>

    <!-- ========= SOUND FEATURES ========= -->
    <sys:String x:Key="EventSounds_Title">Event sounds</sys:String>
    <sys:String x:Key="EventSounds_Desc">Plays sound effects for events like game launch, Playnite start/exit, and library updates. Works with sounds included in the theme.</sys:String>
    <sys:String x:Key="EventSounds_Enable">Enable event sounds</sys:String>
    <sys:String x:Key="EventSounds_Help">If enabled, disable UI/event sounds from the PlayniteSounds plugin to avoid duplicate audio.</sys:String>

    <!-- ========= GameOverlay FEATURES ========= -->
    <sys:String x:Key="InGameOverlay_Tab">In-Game Overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Title">In-Game Overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Desc">Display an Aniki quick action panel on top of the current game.</sys:String>

    <sys:String x:Key="InGameOverlay_Settings_Title">Overlay settings</sys:String>
    <sys:String x:Key="InGameOverlay_Settings_Desc">Configure the Aniki in-game overlay and its keyboard shortcut.</sys:String>

    <sys:String x:Key="InGameOverlay_Enable">Enable in-game overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Enable_Help">Enables Aniki Helper’s own in-game overlay. Disable this if you prefer to use Playnite’s overlay or another overlay solution.</sys:String>

    <sys:String x:Key="InGameOverlay_Hotkey_Title">Overlay shortcut</sys:String>
    <sys:String x:Key="InGameOverlay_Hotkey_Help">Choose the keyboard shortcut used to open the in-game overlay. Restart Playnite after changing this setting.</sys:String>

    <sys:String x:Key="InGameOverlay_ControllerShortcut_Title">Controller shortcut</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Help">Choose the controller shortcut used to open the in-game overlay. Guide button support is experimental and may be captured by Steam, Windows, or controller tools.</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_StartBack">Start + Back</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_BackY">Back + Y</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Guide">Guide button</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Disabled">Disabled</sys:String>

    <sys:String x:Key="InGameOverlay_GameBehavior_Title">Game behavior while overlay is open</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_DoNothing">Default: Do nothing</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_SuspendGame">Experimental: Suspend game while overlay is open</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Help">Choose whether Aniki Helper should leave the game running normally or temporarily freeze the game process while the overlay is open to avoid double inputs.</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Warning">Warning: not recommended for online games, multiplayer games, anti-cheat protected games, or games launched as administrator.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Title">Never suspend games</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Help">Games added from right-click → Aniki Helper → Overlay Settings → Never suspend this game appear here. Uncheck a game to remove it from the never suspend list.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Clear">Clear never suspend list</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayNeverSuspendThisGame">Never suspend this game</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayAllowSuspendThisGame">Allow suspend for this game</sys:String>

    <sys:String x:Key="InGameOverlay_Limitations_Title">Limitations</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Desc">This overlay is a transparent window displayed above the game. It is not injected directly into the game like Steam or Discord overlays.</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Help">It works best with borderless or windowed fullscreen games. Some exclusive fullscreen games, anti-cheat systems, or elevated games may prevent the overlay from appearing correctly.</sys:String>

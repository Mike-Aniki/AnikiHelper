    <sys:String x:Key="LOCDebugLogsTitle">Debug</sys:String>
    <sys:String x:Key="LOCDebugLogsDescription">Enable this only when troubleshooting an issue and when you need to send a debug report. It writes detailed Aniki Helper information to extensions.log and may generate a lot of log entries.</sys:String>
    <sys:String x:Key="LOCEnableDebugLogs">Enable debug logs</sys:String>

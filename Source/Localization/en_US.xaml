    <!-- ========= ACHIEVEMENTS CACHE ========= -->
    <sys:String x:Key="AchievementCache_Title">Achievement Memories Cache</sys:String>
    <sys:String x:Key="AchievementCache_Desc">Rebuilds achievement memories from PlayniteAchievements. Use this if icons, recent achievements, or rarity data are missing or outdated.</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild">Achievement Memories</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Button">Rebuild cache</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Help">Scans PlayniteAchievements and rebuilds the achievement memories displayed in the theme. This may take some time on large libraries.</sys:String>

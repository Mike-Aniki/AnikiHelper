                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="AppTitle">Aniki Helper</sys:String>
    <sys:String x:Key="AppSubtitle">Ajustes</sys:String>
    <sys:String x:Key="AppInfo">Diseñado para el tema Aniki ReMake. Algunas funciones pueden requerir compatibilidad del tema para funcionar en otros temas.</sys:String>
    <sys:String x:Key="GroupAdditionalFeatures">Funciones adicionales</sys:String>
    <sys:String x:Key="MoreOptionsDesktop">Hay más opciones disponibles en la configuración del plugin desde el modo escritorio de Playnite.</sys:String>

    <sys:String x:Key="GroupGeneral">General</sys:String>
    <sys:String x:Key="GroupNews">Noticias</sys:String>
    <sys:String x:Key="GroupDynamicColors">Colores dinámicos</sys:String>
    <sys:String x:Key="GameLaunchSplash_VideoVolume_Title">Volumen del vídeo</sys:String>

    <sys:String x:Key="LOCDebugLogsTitle">Depuración</sys:String>
    <sys:String x:Key="LOCDebugLogsDescription">Activa esta opción solo para diagnosticar un problema y si necesitas enviar un informe de depuración. Escribe información detallada de Aniki Helper en extensions.log y puede generar muchas entradas de registro.</sys:String>
    <sys:String x:Key="LOCEnableDebugLogs">Activar registros de depuración</sys:String>
    <sys:String x:Key="LOCDebugLogsInfo">Para un informe de depuración limpio: limpia el archivo de registro, activa el modo de depuración, reproduce el error y envía el archivo extensions.log.</sys:String>
    <sys:String x:Key="LOCClearLogFile">Limpiar archivo log</sys:String>
    <sys:String x:Key="LOCOpenLogsFolder">Abrir carpeta de logs</sys:String>
    
    <!-- ========= HUB FEATURES ========= -->
    <sys:String x:Key="WelcomeHubStartup_Title">Pantalla de inicio</sys:String>
    <sys:String x:Key="WelcomeHubStartup_Desc">Elige qué pantalla se muestra al iniciar Playnite: tu biblioteca o el Hub.</sys:String>
    <sys:String x:Key="WelcomeHubStartup_Enable">Abrir el Hub al iniciar</sys:String>
    <sys:String x:Key="WelcomeHubStartup_Help">Si está desactivado, Playnite se abrirá directamente en tu biblioteca.</sys:String>

    <!-- ========= LIBRARY STAT FEATURES ========= -->
    <sys:String x:Key="GroupLibraryStats">Estadísticas de la biblioteca</sys:String>
    <sys:String x:Key="StatsHelp">Elige qué juegos se incluyen en las estadísticas que muestra el tema.</sys:String>
    <sys:String x:Key="IncludeHidden">Incluir juegos ocultos</sys:String>
    <sys:String x:Key="AutoUpdate">Las estadísticas se actualizan automáticamente cuando cambia tu biblioteca.</sys:String>
    <sys:String x:Key="PreviewTotal">Vista previa — Total:</sys:String>
    <sys:String x:Key="Installed">Instalados:</sys:String>
    <sys:String x:Key="NotInstalled">No instalados:</sys:String>

    <!-- ========= MEDIA GALLERY ========= -->
    <sys:String x:Key="MediaGallery_Title">Galería multimedia</sys:String>
    <sys:String x:Key="MediaGallery_Desc">Aniki Helper lee los medios desde Screenshots Visualizer y Screenshot Utilities. Configura tus carpetas de capturas en esos plugins; Aniki Helper solo lee sus datos y genera miniaturas para acelerar la navegación en el tema.</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Title">Proveedor de capturas</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Visualizer">Screenshots Visualizer</sys:String>
    <sys:String x:Key="MediaGallery_GenerateThumbnails_Help">Pregenera miniaturas para todas las imágenes de los plugins de capturas. La primera generación puede tardar un poco, pero las siguientes deberían ser más rápidas.</sys:String>
    <sys:String x:Key="MediaGallery_Provider_UtilitiesLocal">Screenshot Utilities - Local</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Help">El tema usará la lista multimedia de Aniki Helper en lugar de enlazarse directamente al plugin de capturas seleccionado.</sys:String>
    <sys:String x:Key="LOCAnikiHelperGenerateThumbnailsForGame">Generar miniaturas para este juego</sys:String>
    <sys:String x:Key="LOCAnikiHelperScanningMediaForThisGame">Analizando archivos multimedia de este juego...</sys:String>
    <sys:String x:Key="LOCAnikiHelperThumbnailGenerationCancelled">Generación de miniaturas cancelada.</sys:String>
    <sys:String x:Key="LOCAnikiHelperGeneratingThumbnailsForGame">Generando miniaturas para {0}... {1}/{2}</sys:String>
    <sys:String x:Key="LOCAnikiHelperUpdatingMediaCache">Actualizando caché multimedia...</sys:String>
    <sys:String x:Key="LOCAnikiHelperThumbnailsGenerated">Miniaturas generadas.</sys:String>
    <sys:String x:Key="LOCAnikiHelperGeneratingGameThumbnails">Generando miniaturas del juego</sys:String>

    <!-- ========= CUSTOM ICONS ========= -->
    <sys:String x:Key="CustomIcons_Title">Iconos personalizados</sys:String>
    <sys:String x:Key="CustomIcons_Desc">Elige carpetas externas para los iconos personalizados de filtros y fuentes. Estos iconos sustituyen a los iconos predeterminados del tema sin modificar sus archivos.</sys:String>
    <sys:String x:Key="CustomIcons_FilterFolder">Carpeta de iconos de filtros</sys:String>
    <sys:String x:Key="CustomIcons_SourceFolder">Carpeta de iconos de fuentes</sys:String>
    <sys:String x:Key="CustomIcons_Help">Los archivos PNG deben usar exactamente los mismos nombres que los filtros o fuentes mostrados en Playnite. Ejemplo: Installed.png, Favorites.png, Steam.png.</sys:String>
    <sys:String x:Key="BrowseFolder">Examinar...</sys:String>
    <sys:String x:Key="CustomIcons_SelectFilterFolderDialog">Selecciona la carpeta que contiene tus iconos PNG de filtros.</sys:String>
    <sys:String x:Key="CustomIcons_SelectSourceFolderDialog">Selecciona la carpeta que contiene tus iconos PNG de fuentes.</sys:String>

    <!-- ========= GameOverlay ========= -->
    <sys:String x:Key="InGameOverlay_Tab">Overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Title">Overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Desc">Muestra un panel de acciones rápidas de Aniki encima del juego actual.</sys:String>
    
    <sys:String x:Key="InGameOverlay_Settings_Title">Ajustes del overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Settings_Desc">Configura el overlay en juego de Aniki y su atajo de teclado.</sys:String>

    <sys:String x:Key="InGameOverlay_Enable">Activar overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Enable_Help">Activa el overlay en juego propio de Aniki Helper. Desactiva esta opción si prefieres usar el overlay de Playnite u otra solución de overlay.</sys:String>
    
    <sys:String x:Key="InGameOverlay_Hotkey_Title">Atajo del overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Hotkey_Help">Elige el atajo de teclado utilizado para abrir el overlay en juego. Reinicia Playnite después de cambiar este ajuste.</sys:String>

    <sys:String x:Key="InGameOverlay_ControllerShortcut_Title">Atajo del mando</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Help">Elige el atajo del mando utilizado para abrir el overlay en juego. El botón Guide es experimental y puede ser capturado por Steam, Windows o herramientas de mando.</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_StartBack">Start + Back</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_BackY">Back + Y</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Guide">Botón Guide</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Disabled">Desactivado</sys:String>
    
    <sys:String x:Key="InGameOverlay_Limitations_Title">Limitaciones</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Desc">Este overlay es una ventana transparente mostrada encima del juego. No se inyecta directamente en el juego como los overlays de Steam o Discord.</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Help">Funciona mejor con juegos en modo ventana sin bordes o pantalla completa en ventana. Algunos juegos en pantalla completa exclusiva, anti-cheats o juegos ejecutados como administrador pueden impedir que el overlay se muestre correctamente.</sys:String>

    <sys:String x:Key="LOCInGameOverlayCancel">Cancelar</sys:String>
    <sys:String x:Key="LOCInGameOverlayConfirmQuit">Salir del juego</sys:String>
    
    <!-- ========= TRACK PLAYTIME FEATURES ========= -->
    <sys:String x:Key="GroupMonthly">Historial mensual</sys:String>
    <sys:String x:Key="ResetSectionTitle">Restablecer el seguimiento del mes actual</sys:String>
    <sys:String x:Key="BackupSectionTitle">Guardar y restaurar tu historial</sys:String>

    <sys:String x:Key="MonthlyHelp">Registra tu tiempo de juego cada mes para que el tema pueda mostrar estadísticas como el tiempo jugado este mes, los juegos jugados y tu juego más jugado.</sys:String>
    <sys:String x:Key="CurrentMonthData">Mes actual:</sys:String>
    <sys:String x:Key="SnapshotTooltip">Muestra cuándo comenzó el seguimiento del mes actual.</sys:String>

    <sys:String x:Key="ResetWarningText">Advertencia: esto elimina los datos de seguimiento del mes actual.</sys:String>
    <sys:String x:Key="ResetBtn">Restablecer seguimiento del mes actual</sys:String>
    <sys:String x:Key="ResetBtnTooltip">Elimina los datos de seguimiento del mes actual y vuelve a empezar desde ahora.</sys:String>
    <sys:String x:Key="ResetBtntip">No uses esto a menos que realmente quieras borrar el seguimiento de este mes. Las estadísticas mensuales del mes actual se reiniciarán desde cero después del restablecimiento.</sys:String>

    <sys:String x:Key="ExportMonthlyBackupBtn">Exportar historial</sys:String>
    <sys:String x:Key="ImportMonthlyBackupBtn">Importar historial</sys:String>
    <sys:String x:Key="ExportMonthlyBackupTooltip">Exporta todos los datos de seguimiento mensual a un archivo de copia de seguridad.</sys:String>
    <sys:String x:Key="ImportMonthlyBackupTooltip">Importa una copia de seguridad de seguimiento mensual guardada anteriormente.</sys:String>
    <sys:String x:Key="MonthlyBackupHelp">Usa estos botones para hacer una copia de seguridad o restaurar todos los datos de seguimiento mensual. Esto resulta útil antes de reinstalar Playnite o restablecer tu biblioteca.</sys:String>

    <!-- ========= VIDEO FEATURES ========= -->
    <sys:String x:Key="Video">Vídeo</sys:String>

    <sys:String x:Key="StartupIntro_Title">Vídeo de introducción al iniciar</sys:String>
    <sys:String x:Key="StartupIntro_Desc">Reproduce un vídeo de introducción al iniciar Playnite.</sys:String>
    <sys:String x:Key="StartupIntro_Enable">Activar vídeo de introducción al iniciar</sys:String>
    <sys:String x:Key="IntroVideo_Help">Desactiva esto para iniciar Playnite sin el vídeo de introducción.</sys:String>

    <sys:String x:Key="ShutdownVideo_Title">Vídeo de cierre</sys:String>
    <sys:String x:Key="ShutdownVideo_Desc">Reproduce un vídeo de cierre al cerrar Playnite.</sys:String>
    <sys:String x:Key="ShutdownVideo_Enable">Activar vídeo de cierre</sys:String>
    <sys:String x:Key="ShutdownVideo_Help">Desactiva esto para cerrar Playnite sin el vídeo de cierre.</sys:String>

    <!-- ========= SOUND FEATURES ========= -->
    <sys:String x:Key="EventSounds_Title">Sonidos de eventos</sys:String>
    <sys:String x:Key="EventSounds_Desc">Reproduce efectos de sonido para eventos como el inicio de juegos, el arranque/salida de Playnite y las actualizaciones de la biblioteca. Funciona con los sonidos incluidos en el tema.</sys:String>
    <sys:String x:Key="EventSounds_Enable">Activar sonidos de eventos</sys:String>
    <sys:String x:Key="EventSounds_Help">Si está activado, desactiva los sonidos de interfaz/eventos del plugin PlayniteSounds para evitar audio duplicado.</sys:String>

    <!-- ========= SPLASH FEATURES ========= -->
    <sys:String x:Key="SplashScreen">Pantalla de carga</sys:String>
    <sys:String x:Key="GameLaunchSplash_Title">Pantalla de inicio de los juegos</sys:String>
    <sys:String x:Key="GameLaunchSplash_Desc">Muestra una imagen o un vídeo de inicio cuando se lanza un juego. Puedes gestionar pantallas de carga personalizadas desde el menú de clic derecho de un juego.</sys:String>
    <sys:String x:Key="GameLaunchSplash_Enable">Activar pantalla de inicio de los juegos</sys:String>
    <sys:String x:Key="GameLaunchSplash_Help">Desactiva esta opción si quieres iniciar los juegos sin pantalla de carga.</sys:String>


    <sys:String x:Key="SplashScreen">Pantalla de carga</sys:String>
    <sys:String x:Key="GameLaunchSplash_Title">Pantalla de inicio de los juegos</sys:String>
    <sys:String x:Key="GameLaunchSplash_Desc">Muestra una imagen o un vídeo de inicio cuando se lanza un juego. Puedes gestionar pantallas de carga personalizadas desde el menú de clic derecho de un juego.</sys:String>
    <sys:String x:Key="GameLaunchSplash_Enable">Activar pantalla de inicio de los juegos</sys:String>
    <sys:String x:Key="GameLaunchSplash_Help">Desactiva esta opción si quieres iniciar los juegos sin pantalla de carga.</sys:String>


    <sys:String x:Key="SteamPlayers_Help">Activa o desactiva la visualización del número de jugadores en el tema.</sys:String>

    <!-- Steam Store -->
    <sys:String x:Key="SteamStore_GroupTitle">Steam Store</sys:String>
    <sys:String x:Key="SteamStore_GroupDesc">Configura cómo se muestra el contenido de Steam Store en el tema.</sys:String>

    <sys:String x:Key="SteamStore_Language_Title">Idioma de la tienda</sys:String>
    <sys:String x:Key="SteamStore_Language_Desc">Elige el idioma usado para el contenido de Steam Store.</sys:String>
    <sys:String x:Key="SteamStore_Language_Label">Idioma</sys:String>

    <sys:String x:Key="SteamStore_Country_Title">País de la tienda</sys:String>
    <sys:String x:Key="SteamStore_Country_Desc">Elige el país usado para los precios y la moneda.</sys:String>
    <sys:String x:Key="SteamStore_Country_Label">País</sys:String>
    <sys:String x:Key="SteamStore_Country_Help">Esto afecta a los precios regionales y a la moneda mostrada.</sys:String>

    <sys:String x:Key="SteamStore_Enable_Title">Integración de Steam Store</sys:String>
    <sys:String x:Key="SteamStore_Enable">Activar Steam Store</sys:String>
    <sys:String x:Key="SteamStore_Enable_Desc">Activa las secciones de Steam Store dentro del tema.</sys:String>
    <sys:String x:Key="SteamStore_Enable_Help">Si está desactivado, el botón Store dejará de mostrarse en el tema.</sys:String>


    <!-- Conexión Steam -->
    <sys:String x:Key="SteamAccount_GroupTitle">Conexión de cuenta Steam</sys:String>
    <sys:String x:Key="SteamAccount_GroupDesc">Vincula Steam para activar Mi lista de deseados, For You y Steam Friends.</sys:String>
    <sys:String x:Key="SteamAccount_ConnectButton">Conectar a Steam</sys:String>
    <sys:String x:Key="SteamAccount_ReconnectButton">Volver a conectar a Steam</sys:String>
    <sys:String x:Key="SteamAccount_CheckButton">Comprobar conexión</sys:String>
    <sys:String x:Key="SteamAccount_DisconnectButton">Desconectar</sys:String>
    <sys:String x:Key="SteamAccount_StatusLabel">Estado de conexión</sys:String>
    <sys:String x:Key="SteamAccount_SteamIdLabel">SteamID:</sys:String>
    <sys:String x:Key="SteamAccount_ConfiguredBadge">CONFIGURADA</sys:String>
    <sys:String x:Key="SteamAccount_MissingBadge">FALTA</sys:String>
    <sys:String x:Key="SteamAccount_OptionalBadge">OPCIONAL</sys:String>
    <sys:String x:Key="SteamAccount_ConnectedTitle">Conectado a Steam</sys:String>
    <sys:String x:Key="SteamAccount_ConnectedDesc">Tu sesión de Steam Store está activa. Las secciones personalizadas del Store están disponibles.</sys:String>
    <sys:String x:Key="SteamAccount_DisconnectedTitle">No conectado a Steam</sys:String>
    <sys:String x:Key="SteamAccount_DisconnectedDesc">Inicia sesión para activar Mi lista de deseados, For You y otras secciones personalizadas de Steam Store.</sys:String>
    <sys:String x:Key="SteamAccount_ProfileLabel">Perfil Steam / SteamID detectado</sys:String>
    <sys:String x:Key="SteamAccount_ApiKeyTitle">Clave Steam Web API</sys:String>
    <sys:String x:Key="SteamAccount_ApiKeyDesc">Es necesaria para Steam Friends y se utiliza para mejorar las recomendaciones de la tienda mediante tus juegos adquiridos y jugados recientemente. La tienda puede funcionar sin ella, pero los datos de amigos y algunas funciones de personalización no estarán disponibles.</sys:String>
    <sys:String x:Key="SteamAccount_ManualSteamIdTitle">SteamID de respaldo avanzado</sys:String>
    <sys:String x:Key="SteamAccount_ManualSteamIdDesc">Opcional. Úsalo solo si falla la detección automática del SteamID.</sys:String>
    <sys:String x:Key="SteamAccount_PrivacyNotice">Steam Friends requiere un perfil Steam y una lista de amigos públicos. Un perfil privado puede no devolver datos.</sys:String>

    <!-- Steam Friends -->
    <sys:String x:Key="LOCSteamFriends_Title">Steam Friends</sys:String>
    <sys:String x:Key="LOCSteamFriends_Subtitle">Muestra el estado de tus amigos de Steam dentro del tema Aniki: amigos en línea, juegos actuales, perfiles y notificaciones del tema.</sys:String>
    <sys:String x:Key="LOCSteamFriends_Enable">Activar integración Steam Friends</sys:String>
    <sys:String x:Key="LOCSteamFriends_EnableHelp">Activa o desactiva los datos de Steam Friends usados por el tema.</sys:String>
    <sys:String x:Key="LOCSteamFriends_Display">Visualización</sys:String>
    <sys:String x:Key="LOCSteamFriends_OnlineInfo">El tema puede mostrar hasta 15 amigos en línea a la vez. Los amigos se priorizan por estado: jugando primero, luego en línea, ausente y ocupado.</sys:String>
    <sys:String x:Key="LOCSteamFriends_ShowOffline">Mostrar amigos sin conexión</sys:String>
    <sys:String x:Key="LOCSteamFriends_OfflineInfo">Los amigos sin conexión son opcionales y están limitados a 40 a la vez para mantener una navegación fluida.</sys:String>
    <sys:String x:Key="LOCSteamFriends_Notifications">Notificaciones</sys:String>
    <sys:String x:Key="LOCSteamFriends_NotifyOnGameStart">Notificar cuando un amigo inicia un juego</sys:String>
    <sys:String x:Key="LOCSteamFriends_NotifyOnGameStartHelp">Muestra una notificación dentro del tema cuando un amigo de Steam empieza a jugar.</sys:String>
    <sys:String x:Key="LOCSteamFriends_NotifyOnConnect">Notificar cuando un amigo se conecta</sys:String>
    <sys:String x:Key="LOCSteamFriends_NotifyOnConnectHelp">Muestra una notificación dentro del tema cuando un amigo de Steam se conecta.</sys:String>
    <sys:String x:Key="LOCSteamFriends_PlayedDetails_Title">Detalles del juego</sys:String>
    <sys:String x:Key="LOCSteamFriends_PlayedCache_Section">Juegos jugados por amigos</sys:String>
    <sys:String x:Key="LOCSteamFriends_PlayedCache_Refresh">Actualizar juegos jugados por amigos</sys:String>
    <sys:String x:Key="LOCSteamFriends_PlayedCache_Help">Crea una caché local de Steam para mostrar, en la vista de detalles, los amigos que ya han jugado al juego seleccionado. El análisis puede tardar según el número de amigos.</sys:String>
    <sys:String x:Key="LOCSteamFriends_PlayedCache_Preparing">Preparando la actualización de juegos jugados por amigos...</sys:String>

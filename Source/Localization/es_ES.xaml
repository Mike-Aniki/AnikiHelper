    <!-- ========= ACHIEVEMENTS CACHE ========= -->
    <sys:String x:Key="AchievementCache_Title">Caché de recuerdos de logros</sys:String>
    <sys:String x:Key="AchievementCache_Desc">Reconstruye los recuerdos de logros a partir de PlayniteAchievements. Úsalo si faltan iconos, logros recientes o datos de rareza, o si están desactualizados.</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild">Recuerdos de logros</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Button">Reconstruir caché</sys:String>
    <sys:String x:Key="AchievementCache_Rebuild_Help">Analiza PlayniteAchievements y reconstruye los recuerdos de logros mostrados en el tema. Esto puede tardar en bibliotecas grandes.</sys:String>
    <sys:String x:Key="AchievementCache_Status_Scanning">Analizando logros...</sys:String>
    <sys:String x:Key="AchievementCache_Status_Done">Caché de recuerdos de logros reconstruida: {0} elementos.</sys:String>
    <sys:String x:Key="AchievementCache_Status_Failed">Error al reconstruir la caché de recuerdos de logros.</sys:String>
    <sys:String x:Key="LOCAnikiHelperRefreshAchievementCacheForGame">Actualizar recuerdos de este juego</sys:String>

    
    <!-- ========= CUSTOM ICONS ========= -->
    <sys:String x:Key="CustomIcons_Title">Iconos personalizados</sys:String>
    <sys:String x:Key="CustomIcons_Desc">Elige carpetas externas para iconos de filtros, iconos de fuentes e imágenes de banners. Estos archivos sustituyen los visuales predeterminados del tema sin modificar sus archivos.</sys:String>
    <sys:String x:Key="CustomIcons_FilterFolder">Carpeta de iconos de filtros</sys:String>
    <sys:String x:Key="CustomIcons_SourceFolder">Carpeta de iconos de fuentes</sys:String>
    <sys:String x:Key="CustomIcons_BannerAboveCoverFolder">Carpeta de banners sobre las carátulas</sys:String>
    <sys:String x:Key="CustomIcons_BannerOnCoverFolder">Carpeta de banners en las carátulas</sys:String>
    <sys:String x:Key="CustomIcons_Help">Los archivos PNG deben usar exactamente los mismos nombres que los filtros, fuentes o plataformas mostrados en Playnite. Ejemplos: Installed.png, Favorites.png, Steam.png. Usa carpetas separadas para los banners sobre las carátulas y los banners en las carátulas.</sys:String>
    <sys:String x:Key="BrowseFolder">Examinar...</sys:String>
    <sys:String x:Key="CustomIcons_SelectFilterFolderDialog">Selecciona la carpeta que contiene tus iconos PNG de filtros.</sys:String>
    <sys:String x:Key="CustomIcons_SelectSourceFolderDialog">Selecciona la carpeta que contiene tus iconos PNG de fuentes.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerAboveCoverFolderDialog">Selecciona la carpeta que contiene tus banners PNG sobre las carátulas.</sys:String>
    <sys:String x:Key="CustomIcons_SelectBannerOnCoverFolderDialog">Selecciona la carpeta que contiene tus banners PNG en las carátulas.</sys:String>

    <!-- ========= GameOverlay ========= -->
    <sys:String x:Key="InGameOverlay_Tab">Overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Title">Overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Desc">Muestra un panel de acciones rápidas de Aniki encima del juego actual.</sys:String>
    
    <sys:String x:Key="InGameOverlay_Settings_Title">Ajustes del overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Settings_Desc">Configura el overlay en juego de Aniki y su atajo de teclado.</sys:String>

    <sys:String x:Key="InGameOverlay_Enable">Activar overlay en juego</sys:String>
    <sys:String x:Key="InGameOverlay_Enable_Help">Activa el overlay en juego propio de Aniki Helper. Desactiva esta opción si prefieres usar el overlay de Playnite u otra solución de overlay.</sys:String>
    
    <sys:String x:Key="InGameOverlay_Hotkey_Title">Atajo del overlay</sys:String>
    <sys:String x:Key="InGameOverlay_Hotkey_Help">Elige el atajo de teclado utilizado para abrir el overlay en juego. Reinicia Playnite después de cambiar este ajuste.</sys:String>

    <sys:String x:Key="InGameOverlay_ControllerShortcut_Title">Atajo del mando</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Help">Elige el atajo del mando utilizado para abrir el overlay en juego. El botón Guide es experimental y puede ser capturado por Steam, Windows o herramientas de mando.</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_StartBack">Start + Back</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_BackY">Back + Y</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Guide">Botón Guide</sys:String>
    <sys:String x:Key="InGameOverlay_ControllerShortcut_Disabled">Desactivado</sys:String>

    <sys:String x:Key="InGameOverlay_GameBehavior_Title">Comportamiento del juego mientras el overlay está abierto</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_DoNothing">Predeterminado: no hacer nada</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_SuspendGame">Experimental: suspender el juego mientras el overlay está abierto</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Help">Elige si Aniki Helper debe dejar el juego funcionando normalmente o congelar temporalmente el proceso del juego mientras el overlay está abierto para evitar entradas duplicadas.</sys:String>
    <sys:String x:Key="InGameOverlay_GameBehavior_Warning">Advertencia: no recomendado para juegos online, multijugador, con anti-cheat o iniciados como administrador.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Title">Juegos que nunca se suspenden</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Help">Los juegos añadidos desde clic derecho → Aniki Helper → Overlay Settings → Never suspend this game aparecen aquí. Desmarca un juego para quitarlo de la lista.</sys:String>
    <sys:String x:Key="InGameOverlay_NeverSuspendList_Clear">Vaciar la lista</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayNeverSuspendThisGame">Never suspend this game</sys:String>
    <sys:String x:Key="LOCAnikiHelperOverlayAllowSuspendThisGame">Allow suspend for this game</sys:String>
    
    <sys:String x:Key="InGameOverlay_Limitations_Title">Limitaciones</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Desc">Este overlay es una ventana transparente mostrada encima del juego. No se inyecta directamente en el juego como los overlays de Steam o Discord.</sys:String>
    <sys:String x:Key="InGameOverlay_Limitations_Help">Funciona mejor con juegos en modo ventana sin bordes o pantalla completa en ventana. Algunos juegos en pantalla completa exclusiva, anti-cheats o juegos ejecutados como administrador pueden impedir que el overlay se muestre correctamente.</sys:String>

    <sys:String x:Key="LOCInGameOverlayCancel">Cancelar</sys:String>
    <sys:String x:Key="LOCInGameOverlayConfirmQuit">Salir del juego</sys:String>

    <sys:String x:Key="LOCInGameOverlayFooterTitle">Aniki Control Center</sys:String>
    <sys:String x:Key="LOCInGameOverlayControlCenter">CONTROL CENTER</sys:String>
    <sys:String x:Key="LOCInGameOverlayBackHint">B / Atrás para cerrar</sys:String>
    <sys:String x:Key="LOCInGameOverlayReturnToPlaynite">Volver a Playnite</sys:String>
    <sys:String x:Key="LOCInGameOverlayReturnToGame">Volver al juego</sys:String>
    <sys:String x:Key="LOCInGameOverlayQuitGame">Cerrar juego</sys:String>
    <sys:String x:Key="LOCInGameOverlayGame">Juego</sys:String>
    <sys:String x:Key="LOCInGameOverlayLastCaptures">Últimas capturas</sys:String>
    <sys:String x:Key="LOCInGameOverlayMedia">Media</sys:String>
    <sys:String x:Key="LOCInGameOverlayAchievements">Trofeos</sys:String>
    <sys:String x:Key="LOCInGameOverlayGameInfo">Info del juego</sys:String>

    <sys:String x:Key="LOCOpenLogsFolder">Abrir carpeta de logs</sys:String>
    
    <!-- ========= HUB FEATURES ========= -->
    <sys:String x:Key="WelcomeHubStartup_Title">Pantalla de inicio</sys:String>
    <sys:String x:Key="WelcomeHubStartup_Desc">Elige qué pantalla se muestra al iniciar Playnite: tu biblioteca o el Hub.</sys:String>
    <sys:String x:Key="WelcomeHubStartup_Enable">Abrir el Hub al iniciar</sys:String>

    <sys:String x:Key="HubApps_Title">Apps del Hub</sys:String>
    <sys:String x:Key="HubApps_Desc">Muestra hasta 4 herramientas de software de Playnite seleccionadas directamente en el Hub.</sys:String>
    <sys:String x:Key="HubApps_Enable">Mostrar la página Apps en el Hub</sys:String>
    <sys:String x:Key="HubApps_Slot1">Slot 1</sys:String>
    <sys:String x:Key="HubApps_Slot2">Slot 2</sys:String>
    <sys:String x:Key="HubApps_Slot3">Slot 3</sys:String>
    <sys:String x:Key="HubApps_Slot4">Slot 4</sys:String>
    <sys:String x:Key="HubApps_Help">Elige hasta 4 apps desde las herramientas de software de Playnite para mostrarlas en el Hub. Las apps deben añadirse primero en Playnite / Herramientas de software. Puedes establecer una imagen de fondo personalizada para cada app; si no, se usará una imagen predeterminada.</sys:String>
    <sys:String x:Key="HubApps_SelectBackgroundDialog">Selecciona una imagen de fondo para esta tarjeta de app del Hub.</sys:String>
    <sys:String x:Key="BrowseImage">Imagen...</sys:String>
    <sys:String x:Key="LOCHubAppsTitle">Apps</sys:String>
    <sys:String x:Key="LOCHubAppsSubtitle">Tus Software Tools seleccionados</sys:String>

    <sys:String x:Key="WelcomeHubStartup_Help">Si está desactivado, Playnite se abrirá directamente en tu biblioteca.</sys:String>


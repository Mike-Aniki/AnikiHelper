    <sys:String x:Key="GroupAdditionalFeatures">Funciones adicionales</sys:String>
    <sys:String x:Key="AppInfo">Aniki Helper está diseñado para los temas de la marca Aniki. Las funciones avanzadas solo funcionan con temas Aniki.</sys:String>
    

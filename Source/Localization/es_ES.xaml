    <!-- ========= STEAM FEATURES ========= -->
    <sys:String x:Key="GroupSteamFeatures">Funciones de Steam</sys:String>

    <!-- Steam updates -->
    <sys:String x:Key="SteamUpdates_GroupTitle">Actualizaciones de Steam</sys:String>
    <sys:String x:Key="SteamUpdates_GroupDesc">Cuando está activado, el plugin comprueba las actualizaciones de los juegos directamente desde Steam. Esto permite que el tema muestre tanto entradas de actualización nuevas como antiguas.</sys:String>

    <sys:String x:Key="SteamUpdates_Title">Actualizaciones de juegos</sys:String>
    <sys:String x:Key="SteamUpdates_Desc">Comprueba si tus juegos de Steam tienen actualizaciones recientes.</sys:String>
    <sys:String x:Key="SteamUpdates_Enable">Activar comprobación de actualizaciones</sys:String>
    <sys:String x:Key="SteamUpdates_Enable_Help">Activa o desactiva por completo la comprobación de actualizaciones.</sys:String>

    <!-- Update data -->
    <sys:String x:Key="SteamInitCache_ProgressTitle">Datos de actualizaciones</sys:String>
    <sys:String x:Key="SteamInitCache_ProgressDesc">El plugin comprueba las actualizaciones de los juegos de Steam mientras navegas por tu biblioteca. Puedes ejecutar un análisis completo de la biblioteca para rellenar previamente los datos de actualización de todos tus juegos en lugar de esperar a navegar por ellos uno por uno. Esto ayuda a evitar notificaciones falsas de actualización y mejora el rendimiento durante la navegación.</sys:String>
    <sys:String x:Key="SteamInitCache">Analizar biblioteca</sys:String>
    <sys:String x:Key="SteamInitCache_Tooltip">Analiza tus juegos de Steam y prepara los datos de actualización.</sys:String>
    <sys:String x:Key="SteamInitCache_ProgressNote">Se recomienda analizar la biblioteca para evitar notificaciones falsas y mejorar el rendimiento.</sys:String>
    <sys:String x:Key="SteamInitCache_ProgressText">Analizando… {0}/{1}</sys:String>
    <sys:String x:Key="LOCSteamLastScan">Último análisis:</sys:String>
    <sys:String x:Key="ConfirmInitSteamCache">¿Analizar tu biblioteca ahora?</sys:String>
    <sys:String x:Key="InitSteamCacheDoneMsg">Análisis completado.</sys:String>

    <!-- Current players -->
    <sys:String x:Key="SteamPlayers_GroupTitle">Jugadores actuales</sys:String>
    <sys:String x:Key="SteamPlayers_GroupDesc">Muestra el número de jugadores en tiempo real para los juegos de Steam compatibles.</sys:String>

    <sys:String x:Key="SteamPlayers_Title">Jugadores actuales</sys:String>
    <sys:String x:Key="SteamPlayers_Desc">Muestra cuántas personas están jugando actualmente a un juego.</sys:String>

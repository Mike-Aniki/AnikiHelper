    <!-- ========= DYNAMIC COLORS FEATURES ========= -->
    <sys:String x:Key="GroupDynColors">Colores dinámicos</sys:String>
    <sys:String x:Key="DynColors_Help">Usa esto si los colores no coinciden con los fondos de tus juegos actuales.</sys:String>

    <sys:String x:Key="L_ClearColorCache">Restablecer caché de colores</sys:String>
    <sys:String x:Key="L_ClearColorCache_Desc">Los colores se guardan según el fondo de cada juego. Si cambias los fondos, los colores almacenados pueden quedar desactualizados.</sys:String>
    <sys:String x:Key="L_ClearColorCache_Tooltip">Borra todos los datos de color almacenados y vuelve a generarlos a partir de los fondos actuales.</sys:String>
    <sys:String x:Key="L_ClearColorCache_Done_Title">Aniki Helper</sys:String>

    <!-- ========= MEDIA GALLERY ========= -->

    <sys:String x:Key="MediaGallery_Title">Galería multimedia</sys:String>
    <sys:String x:Key="MediaGallery_Desc">Aniki Helper lee los medios desde Screenshots Visualizer y Screenshot Utilities. Configura tus carpetas de capturas en esos plugins; Aniki Helper solo lee sus datos y genera miniaturas para acelerar la navegación en el tema.</sys:String>

    <sys:String x:Key="MediaGallery_Provider_Title">Plugin de capturas</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Visualizer">Screenshots Visualizer</sys:String>
    <sys:String x:Key="MediaGallery_Provider_UtilitiesLocal">Screenshot Utilities - Local</sys:String>
    <sys:String x:Key="MediaGallery_Provider_Help">El tema usará la lista multimedia de Aniki Helper en lugar de enlazarse directamente al plugin de capturas seleccionado.</sys:String>

    <sys:String x:Key="MediaGallery_GenerateThumbnails">Miniaturas multimedia</sys:String>
    <sys:String x:Key="MediaGallery_GenerateThumbnails_Button">Generar miniaturas</sys:String>
    <sys:String x:Key="MediaGallery_GenerateThumbnails_Help">Pre-genera miniaturas para todas las imágenes de los plugins de capturas. La primera generación puede tardar, pero las siguientes deberían ser más rápidas.</sys:String>

    <sys:String x:Key="MediaGallery_Status_WindowTitle">Generar miniaturas</sys:String>
    <sys:String x:Key="MediaGallery_Status_Scanning">Analizando archivos multimedia...</sys:String>

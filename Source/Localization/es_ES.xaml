    <!-- ========= SOUND FEATURES ========= -->
    <sys:String x:Key="EventSounds_Title">Sonidos de eventos</sys:String>
    <sys:String x:Key="EventSounds_Desc">Reproduce efectos de sonido para eventos como el inicio de juegos, el arranque/salida de Playnite y las actualizaciones de la biblioteca. Funciona con los sonidos incluidos en el tema.</sys:String>
    <sys:String x:Key="EventSounds_Enable">Activar sonidos de eventos</sys:String>
    <sys:String x:Key="EventSounds_Help">Si está activado, desactiva los sonidos de interfaz/eventos del plugin PlayniteSounds para evitar audio duplicado.</sys:String>


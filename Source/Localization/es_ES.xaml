    <sys:String x:Key="GameLaunchSplash_LogoPosition_LeftTop">Arriba a la izquierda</sys:String>
    <sys:String x:Key="GameLaunchSplash_LogoPosition_LeftCenter">Centro izquierda</sys:String>
